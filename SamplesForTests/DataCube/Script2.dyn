    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Excel Data Extractor ## Revit 2023 / Dynamo 2.16 / CPython3\r\n\r\n# Developed By - Chris Staker\r\n# v2.0.0 - Semantic Versioning. Output structured as a Dictionary for seamless downstream consumption. Fixed column name casing bug.\r\n\r\nimport sys\r\nimport os\r\nimport ctypes\r\n\r\n# Add custom Python support packages path\r\n# v1.0.0 (Kevin branch) - fixed sys.path for multi-machine support\r\n_pkg_paths = [\r\n    r\"C:\\Dynamo\\2.16\\Python Support Pckg\",\r\n    r\"K:\\CAD\\_Revit2023\\Add_Ins\\Python Support Pckg\",\r\n]\r\nfor _p in _pkg_paths:\r\n    import os as _os\r\n    if _os.path.isdir(_p) and _p not in sys.path:\r\n        sys.path.insert(0, _p)\r\n        break\r\n\r\ntry:\r\n    from openpyxl import load_workbook\r\nexcept ImportError:\r\n    raise ImportError(\r\n        \"openpyxl not found. The Python Support Package must be installed at one of:\\n\"\r\n        \"  C:\\\\Dynamo\\\\2.16\\\\Python Support Pckg\\n\"\r\n        \"  K:\\\\CAD\\\\_Revit2023\\\\Add_Ins\\\\Python Support Pckg\\n\"\r\n        \"Ask your BIM manager to set up the Python Support Package on this machine.\"\r\n    )\r\n\r\n# Get inputs from Dynamo\r\nfile_path = IN[0]\r\ntable_name = IN[1]\r\nexcel_to_revit_mapping_list = IN[2]\r\nheader_row_index_input = IN[3] if len(IN) > 3 else None\r\nprimary_filter_input = IN[4] if len(IN) > 4 else None\r\nsupplementary_filter_input = IN[5] if len(IN) > 5 else None\r\n\r\ndef show_popup_message(title, message, icon_type=0, button_type=0):\r\n    try:\r\n        return ctypes.windll.user32.MessageBoxW(0, message, title, icon_type | button_type)\r\n    except:\r\n        return 1\r\n\r\ndef matches_filter_value(cell_value, filter_value):\r\n    if cell_value is None:\r\n        cell_str = \"\"\r\n    else:\r\n        cell_str = str(cell_value).strip().lower()\r\n    filter_str = str(filter_value).strip().lower()\r\n    return filter_str in cell_str\r\n\r\ndef check_supplementary_filters(record, supp_filter_config, column_indices):\r\n    if not supp_filter_config or 'filters' not in supp_filter_config:\r\n        return True \r\n    \r\n    logic = supp_filter_config.get('logic', 'AND').upper()\r\n    filters = supp_filter_config['filters']\r\n    matches = []\r\n    \r\n    for filter_column, filter_values in filters:\r\n        column_lower = filter_column.strip().lower()\r\n        if column_lower not in column_indices:\r\n            matches.append(False)\r\n            continue\r\n        \r\n        cell_value = record.get(column_lower)\r\n        column_match = any(matches_filter_value(cell_value, fv) for fv in filter_values)\r\n        matches.append(column_match)\r\n    \r\n    return all(matches) if logic == 'AND' else any(matches)\r\n\r\ndef group_data_by_filters(data, primary_filter_config, supp_filter_config, column_indices):\r\n    if not primary_filter_config or len(primary_filter_config) != 2:\r\n        return {'All': data}\r\n    \r\n    primary_column, primary_values = primary_filter_config\r\n    primary_column_lower = primary_column.strip().lower()\r\n    \r\n    if primary_column_lower not in column_indices:\r\n        return {'All': data}\r\n    \r\n    grouped = {filter_val: [] for filter_val in primary_values}\r\n    grouped['Other'] = []\r\n    \r\n    for record in data:\r\n        cell_value = record.get(primary_column_lower)\r\n        matched_group = None\r\n        \r\n        for filter_val in primary_values:\r\n            if matches_filter_value(cell_value, filter_val):\r\n                matched_group = filter_val\r\n                break\r\n        \r\n        if matched_group is None:\r\n            grouped['Other'].append(record)\r\n            continue\r\n        \r\n        if check_supplementary_filters(record, supp_filter_config, column_indices):\r\n            grouped[matched_group].append(record)\r\n        else:\r\n            grouped['Other'].append(record)\r\n            \r\n    return grouped\r\n\r\ndef build_output_structure(grouped_data, formatted_mapping):\r\n    flat_data = []\r\n    log_entries = []\r\n    \r\n    sorted_groups = sorted([k for k in grouped_data.keys() if k != 'Other'])\r\n    if 'Other' in grouped_data:\r\n        sorted_groups.append('Other')\r\n    \r\n    for idx, group_name in enumerate(sorted_groups):\r\n        group_data = grouped_data[group_name]\r\n        if group_data:\r\n            flat_data.extend(group_data)\r\n            log_entries.append({\r\n                'Group': group_name,\r\n                'Count': len(group_data),\r\n                'Output Index': idx\r\n            })\r\n            \r\n    # Output cleanly as a dictionary for downstream nodes\r\n    return {\r\n        \"GroupedData\": grouped_data,\r\n        \"FlatData\": flat_data,\r\n        \"Mapping\": formatted_mapping,\r\n        \"Log\": log_entries\r\n    }\r\n\r\ndef read_excel_data(file_path, table_name, mapping_list, header_row_input=None, primary_filter=None, supp_filter=None):\r\n    if not os.path.exists(file_path):\r\n        return {\"Error\": f\"File not found at {file_path}\"}\r\n    \r\n    while True:\r\n        workbook = None\r\n        try:\r\n            try:\r\n                workbook = load_workbook(file_path, read_only=True, keep_vba=True, data_only=True)\r\n                if table_name not in workbook.sheetnames:\r\n                    return {\"Error\": f\"'{table_name}' sheet not found.\"}\r\n                            \r\n                worksheet = workbook[table_name]\r\n\r\n                def coerce_header_row_index(val):\r\n                    if val is None: return 1\r\n                    try:\r\n                        idx = int(float(str(val).strip()))\r\n                        return max(idx, 1)\r\n                    except: return 1\r\n\r\n                header_row_index = coerce_header_row_index(header_row_input)\r\n                max_rows = worksheet.max_row if worksheet.max_row is not None else 1\r\n                if header_row_index > max_rows: header_row_index = 1\r\n                            \r\n                headers = [str(cell.value).strip().lower() if cell.value else None for cell in worksheet[header_row_index]]\r\n                excel_columns = [item[0] for item in mapping_list]\r\n                column_indices = {}\r\n                            \r\n                for col in excel_columns:\r\n                    try:\r\n                        column_indices[col] = headers.index(col.strip().lower())\r\n                    except ValueError:\r\n                        return {\"Error\": f\"Column '{col}' not found.\"}\r\n                \r\n                all_column_indices = {header: idx for idx, header in enumerate(headers) if header}\r\n                data = []\r\n                \r\n                for row_num, row in enumerate(worksheet.iter_rows(min_row=header_row_index + 1), start=header_row_index + 1):\r\n                    record = {}\r\n                    for col_name, col_idx in all_column_indices.items():\r\n                        if col_idx < len(row):\r\n                            record[col_name] = row[col_idx].value\r\n                            \r\n                    if any(record.get(headers[column_indices[col]]) is not None for col in excel_columns if col in column_indices):\r\n                        data.append(record)\r\n                                \r\n            finally:\r\n                if workbook: workbook.close()\r\n            \r\n            grouped_data = group_data_by_filters(data, primary_filter, supp_filter, all_column_indices)\r\n            formatted_mapping = [{'Excel Header': pair[0], 'Revit Parameter': pair[1]} for pair in mapping_list]\r\n            return build_output_structure(grouped_data, formatted_mapping)\r\n        \r\n        except (PermissionError, OSError):\r\n            res = show_popup_message(\"File Access Error\", f\"Excel file '{os.path.basename(file_path)}' is open.\", 0, 53)\r\n            if res == 4: continue\r\n            else: return {\"Error\": \"Operation cancelled by user.\"}\r\n        except Exception as e:\r\n            return {\"Error\": str(e)}\r\n\r\nOUT = read_excel_data(file_path, table_name, excel_to_revit_mapping_list, header_row_index_input, primary_filter_input, supplementary_filter_input)",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
