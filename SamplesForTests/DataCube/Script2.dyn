    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Revit Parameter Writer\n# Revit 2023 / Dynamo 2.16 / CPython3\n# Developed By - Chris Staker & Kevin Levasseur\n# v9.8.0 - Fixed element_lookup: use existing_connectors instead of all_elements.\n#           Prevents Data Cubes (or any non-connector element with Connection ID set)\n#           from overwriting connector entries and blocking all parameter writes.\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 1 — IMPORTS & CLR REFERENCES\n# ═══════════════════════════════════════════════════════════════════════════════\n\nimport sys\nimport clr\n\nclr.AddReference('RevitAPI')\nfrom Autodesk.Revit.DB import (\n    FilteredElementCollector, StorageType, LocationPoint, XYZ,\n    BuiltInParameter, BuiltInCategory\n)\n\nclr.AddReference('RevitServices')\nimport RevitServices\nfrom RevitServices.Persistence import DocumentManager\nfrom RevitServices.Transactions import TransactionManager\n\nclr.AddReference('System.Windows.Forms')\nclr.AddReference('System.Drawing')\nimport System.Windows.Forms as WinForms\nimport System.Drawing as Drawing\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 2 — INPUTS\n#\n#   IN[0] extractor_output  — structured dict from Excel Data Extractor node\n#   IN[1] (unused)          — legacy raw_mapping_table, superseded by UM-Revit Mapping\n#   IN[2] categories_input  — list of Revit category name strings to collect from\n#   IN[3] key_parameter     — Revit parameter name used as the match key (Connection ID)\n#   IN[4] excel_file_path   — path to the Utility Matrix .xlsx file\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndoc              = DocumentManager.Instance.CurrentDBDocument\nextractor_output = IN[0]\n# IN[1] intentionally not consumed — UM-Revit Mapping is read directly from Excel\ncategories_input = IN[2]\nkey_parameter    = IN[3]\nexcel_file_path  = IN[4] if len(IN) > 4 else None\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 3 — UTILITY HELPER FUNCTIONS\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef safe_get(obj, key, default=None):\n    \"\"\"Key-safe getter for Python dicts, IronPython dicts, and Dynamo dicts.\"\"\"\n    try:\n        if hasattr(obj, \"get\"):\n            val = obj.get(key)\n            return val if val is not None else default\n        elif hasattr(obj, \"ContainsKey\"):\n            if obj.ContainsKey(key):\n                val = obj[key]\n                return val if val is not None else default\n        elif hasattr(obj, \"Keys\"):\n            for k in obj.Keys:\n                if str(k) == str(key):\n                    val = obj.GetValueAtKey(k) if hasattr(obj, \"GetValueAtKey\") else obj[k]\n                    return val if val is not None else default\n    except:\n        pass\n    return default\n\ndef get_param_value(elem, name):\n    \"\"\"Returns raw parameter value (Double, Integer, or String).\"\"\"\n    p = elem.LookupParameter(name)\n    if not p: return None\n    if p.StorageType == StorageType.Double:   return p.AsDouble()\n    elif p.StorageType == StorageType.Integer: return p.AsInteger()\n    else:                                      return p.AsString()\n\ndef get_param_display_value(param):\n    \"\"\"Returns the display string for a Revit parameter.\"\"\"\n    if not param: return \"\"\n    st = param.StorageType\n    if st == StorageType.String:\n        return param.AsString() or \"\"\n    elif st == StorageType.Double:\n        try:\n            v = param.AsValueString()\n            if v: return v\n        except:\n            pass\n        return str(round(param.AsDouble(), 4)) if param.AsDouble() is not None else \"\"\n    elif st == StorageType.Integer:\n        return str(param.AsInteger())\n    elif st == StorageType.ElementId:\n        return str(param.AsElementId().IntegerValue)\n    return \"\"\n\ndef check_param_match(param, target_val):\n    \"\"\"Returns True if the Revit parameter's current value matches target_val.\"\"\"\n    if not param or target_val is None: return False\n    st         = param.StorageType\n    target_str = str(target_val).strip()\n    if st == StorageType.String:\n        return (param.AsString() or \"\").strip().upper() == target_str.upper()\n    elif st == StorageType.Double:\n        revit_str = param.AsValueString()\n        if revit_str:\n            if revit_str == target_str:        return True\n            if revit_str == target_str + '\"':  return True\n            if revit_str == target_str + \"'\":  return True\n        try:\n            if param.AsDouble() is not None and abs(param.AsDouble() - float(target_val)) < 0.0001:\n                return True\n        except:\n            pass\n        return False\n    elif st == StorageType.Integer:\n        try:   return param.AsInteger() == int(float(target_val))\n        except: return False\n    return False\n\ndef compare_and_set_param(param, value):\n    \"\"\"\n    Idempotent parameter setter. Compares using Revit's own stored value as\n    ground truth — writes the value then reads back to confirm whether Revit's\n    internal representation actually changed. This guarantees that running the\n    same Excel data twice produces zero updates on the second pass.\n\n    Returns (was_changed: bool, after_display_value: str).\n    \"\"\"\n    if not param or param.IsReadOnly or value is None:\n        return False, get_param_display_value(param)\n\n    st        = param.StorageType\n    value_str = str(value).strip()\n\n    try:\n        if st == StorageType.String:\n            # Normalize to stripped uppercase — that is exactly what we store.\n            before_norm = (param.AsString() or \"\").strip().upper()\n            target_norm = value_str.upper()\n            if before_norm == target_norm:\n                # Already exactly correct — no write needed.\n                return False, param.AsString() or \"\"\n            param.Set(target_norm)\n            # Read back what Revit actually stored (should be target_norm).\n            return True, param.AsString() or \"\"\n\n        elif st == StorageType.Double:\n            # Use Revit's own AsDouble() before/after as the ground truth.\n            # SetValueString handles unit strings (e.g. \"2\\\"\", \"3/4\\\"\") natively.\n            before = param.AsDouble()\n            if param.SetValueString(value_str):\n                after = param.AsDouble()\n                changed = (before is None) or (abs(before - after) > 0.0001)\n                return changed, get_param_display_value(param)\n            # SetValueString failed — try raw float (unitless params).\n            try:\n                target_float = float(value)\n                if before is not None and abs(before - target_float) < 0.0001:\n                    return False, get_param_display_value(param)\n                param.Set(target_float)\n                after = param.AsDouble()\n                changed = (before is None) or (abs(before - after) > 0.0001)\n                return changed, get_param_display_value(param)\n            except:\n                return False, get_param_display_value(param)\n\n        elif st == StorageType.Integer:\n            try:\n                target_int = int(float(value))\n                if param.AsInteger() == target_int:\n                    return False, get_param_display_value(param)\n                param.Set(target_int)\n                changed = param.AsInteger() == target_int\n                return changed, get_param_display_value(param)\n            except:\n                return False, get_param_display_value(param)\n\n        return False, get_param_display_value(param)\n    except:\n        return False, get_param_display_value(param)\n\ndef extract_flat_data(data_input):\n    \"\"\"Flattens Extractor output dict or nested list into a flat list of row dicts.\"\"\"\n    flat_data = safe_get(data_input, \"FlatData\")\n    if flat_data is not None:\n        return flat_data\n    is_list_like = (\n        isinstance(data_input, list) or\n        (hasattr(data_input, '__iter__') and\n         not isinstance(data_input, str) and\n         not hasattr(data_input, 'ContainsKey') and\n         not hasattr(data_input, 'keys'))\n    )\n    if is_list_like:\n        flat = []\n        for item in data_input:\n            is_item_list = (\n                isinstance(item, list) or\n                (hasattr(item, '__iter__') and\n                 not isinstance(item, str) and\n                 not hasattr(item, 'ContainsKey') and\n                 not hasattr(item, 'keys'))\n            )\n            if is_item_list:\n                flat.extend(extract_flat_data(item))\n            elif safe_get(item, \"Excel Header\") is None and safe_get(item, \"Log\") is None:\n                flat.append(item)\n        return flat\n    return (\n        [data_input]\n        if (hasattr(data_input, 'keys') or hasattr(data_input, 'ContainsKey'))\n        else []\n    )\n\ndef get_family_name(elem):\n    \"\"\"Returns the Revit family name string for a family instance.\"\"\"\n    try:\n        fn_p = elem.Symbol.get_Parameter(BuiltInParameter.SYMBOL_FAMILY_NAME_PARAM)\n        return fn_p.AsString() if fn_p else \"\"\n    except:\n        return \"\"\n\ndef build_param_map(elem_or_type):\n    \"\"\"Returns a lowercase-name → parameter dict for an element or type.\"\"\"\n    pm = {}\n    try:\n        for p in elem_or_type.Parameters:\n            try: pm[p.Definition.Name.strip().lower()] = p\n            except: pass\n    except:\n        pass\n    return pm\n\ndef get_representative_display(param_names, inst_param_map, type_param_map, preferred_name=None):\n    \"\"\"\n    Return the best display value for a mapped Excel column from the current\n    Revit element/type state.\n\n    preferred_name is used first when provided, then we fall back to the first\n    non-empty mapped parameter display, then finally the first mapped param.\n    \"\"\"\n    ordered_names = []\n    if preferred_name:\n        ordered_names.append(preferred_name.strip().lower())\n    ordered_names.extend(\n        n.strip().lower() for n in param_names\n        if n and n.strip().lower() not in ordered_names\n    )\n\n    first_display = \"\"\n    for name in ordered_names:\n        param = inst_param_map.get(name) or type_param_map.get(name)\n        display = get_param_display_value(param) if param is not None else \"\"\n        if first_display == \"\":\n            first_display = display\n        if str(display).strip() != \"\":\n            return display\n    return first_display\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 4 — UM-REVIT MAPPING READER\n#\n#   Reads the \"UM-Revit Mapping\" sheet from the Utility Matrix Excel file.\n#\n#   Sheet layout (1-indexed rows):\n#     Row 1-2 : notes / warnings\n#     Row 3   : column headers →\n#                 [Utility Matrix Column] [Revit Parameter]\n#                 [Process Data Cube - Generic] [Process Pipe Connector]\n#                 [Process Duct Connector - Round] [Process Electrical Connector]\n#     Row 4+  : data rows, one per Excel column\n#\n#   Returns a dict keyed by lowercase Excel column name:\n#     {\n#       \"connection size\": {\n#           \"params\":   [\"Nominal Diameter\", \"Connection Size\"],\n#           \"families\": [\"Process Pipe Connector\", \"Process Duct Connector - Round\", ...]\n#       }, ...\n#     }\n#   \"families\" lists the family column headers where the row has \"Yes\".\n#   An empty \"families\" list means no restriction — applies to all.\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef read_um_revit_mapping(file_path):\n    um_map = {}\n    if not file_path:\n        return um_map\n    try:\n        _pkg_paths = [\n            r\"C:\\Dynamo\\2.16\\Python Support Pckg\",\n            r\"K:\\CAD\\_Revit2023\\Add_Ins\\Python Support Pckg\",\n        ]\n        for _p in _pkg_paths:\n            import os as _os\n            if _os.path.isdir(_p) and _p not in sys.path:\n                sys.path.insert(0, _p)\n                break\n        from openpyxl import load_workbook\n        wb = load_workbook(file_path, read_only=True, data_only=True)\n        if 'UM-Revit Mapping' not in wb.sheetnames:\n            wb.close()\n            return um_map\n\n        ws = wb['UM-Revit Mapping']\n\n        # Row 3 (1-indexed) = header row — read family column names from cols 3+\n        header_row  = [c.value for c in next(ws.iter_rows(min_row=3, max_row=3))]\n        family_cols = [str(h).strip() for h in header_row[2:] if h]  # e.g. [\"Process Data Cube...\", ...]\n\n        # Rows 4+ are data\n        for row in ws.iter_rows(min_row=4, values_only=True):\n            excel_col   = row[0]\n            revit_param = row[1]\n            if not excel_col or not revit_param:\n                continue\n\n            key         = str(excel_col).strip().lower()\n            params_list = [p.strip() for p in str(revit_param).strip().split(',') if p.strip()]\n\n            # Applicable families: columns where cell value is \"Yes\" (case-insensitive)\n            applicable = []\n            for i, fam_name in enumerate(family_cols):\n                col_idx = i + 2\n                if col_idx < len(row):\n                    cell_val = row[col_idx]\n                    if cell_val and str(cell_val).strip().lower() == \"yes\":\n                        applicable.append(fam_name)\n\n            # Skip rows where no connector family has \"Yes\"\n            # (e.g. Short Circuit Rating — all No or NaN — should never be written)\n            if not applicable:\n                continue\n\n            if key not in um_map:\n                um_map[key] = {\"params\": [], \"families\": set()}\n            for p in params_list:\n                if p not in um_map[key][\"params\"]:\n                    um_map[key][\"params\"].append(p)\n            for f in applicable:\n                um_map[key][\"families\"].add(f)\n\n        wb.close()\n        for k in um_map:\n            um_map[k][\"families\"] = list(um_map[k][\"families\"])\n\n    except Exception:\n        pass  # Fall back to direct param name matching if sheet can't be read\n\n    return um_map\n\n\ndef family_is_applicable(elem_family_name, applicable_families):\n    \"\"\"\n    Returns True if elem_family_name matches any entry in applicable_families\n    (substring match, case-insensitive).\n    NOTE: applicable_families is never empty for valid mapping entries —\n    entries with no 'Yes' family are excluded by read_um_revit_mapping.\n    \"\"\"\n    if not applicable_families:\n        return True\n    efn = elem_family_name.strip().lower()\n    for fam in applicable_families:\n        fam_lower = fam.strip().lower()\n        if fam_lower in efn or efn in fam_lower:\n            return True\n    return False\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 5 — REVIT ELEMENT COLLECTION\n#\n#   Collects all family instances from the specified Revit categories,\n#   then filters to connector families only (family name contains \"Connector\").\n# ═══════════════════════════════════════════════════════════════════════════════\n\nall_doc_categories    = {c.Name: c for c in doc.Settings.Categories}\ncategories_to_process = categories_input if isinstance(categories_input, list) else [categories_input]\n\nall_elements = []\nfor item in categories_to_process:\n    cat_obj = None\n    if hasattr(item, 'Id'):\n        cat_obj = item\n    elif isinstance(item, str) and item in all_doc_categories:\n        cat_obj = all_doc_categories[item]\n    if cat_obj:\n        collector = (FilteredElementCollector(doc)\n                     .OfCategoryId(cat_obj.Id)\n                     .WhereElementIsNotElementType()\n                     .ToElements())\n        all_elements.extend(collector)\n\n# Only process connector family instances\nexisting_connectors = [\n    e for e in all_elements\n    if e.Symbol and \"Connector\" in (e.Symbol.Family.Name or \"\")\n]\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 6 — FAMILY SELECTION DIALOG\n#\n#   WinForms dialog with two independent checklist sections:\n#     MOVE   — reposition connector to its parent Data Cube location\n#     UPDATE — write Utility Matrix parameter values to Revit\n#   All items are unchecked by default. User can check any combination.\n#   Clicking Run returns (move_families: set, update_families: set).\n#   Clicking Cancel returns (None, None) and exits the script.\n# ═══════════════════════════════════════════════════════════════════════════════\n\n# Build family name → instance count map from collected connectors\nfamily_count = {}\nfor ec in existing_connectors:\n    try:\n        fn_p = ec.Symbol.get_Parameter(BuiltInParameter.SYMBOL_FAMILY_NAME_PARAM)\n        fn   = fn_p.AsString() if fn_p else \"Unknown\"\n        family_count[fn] = family_count.get(fn, 0) + 1\n    except:\n        pass\n\ndef show_family_selection_dialog(family_names_with_counts):\n    DEF_FONT   = Drawing.SystemFonts.DefaultFont.FontFamily\n    DARK_BG    = Drawing.Color.FromArgb(45, 45, 48)\n    DARKER_BG  = Drawing.Color.FromArgb(37, 37, 38)\n    DIVIDER    = Drawing.Color.FromArgb(80, 80, 80)\n    SECTION_BG = Drawing.Color.FromArgb(55, 55, 60)\n    WHITE      = Drawing.Color.White\n    GREY       = Drawing.Color.FromArgb(180, 180, 180)\n    BLUE       = Drawing.Color.FromArgb(0, 122, 204)\n    GREEN      = Drawing.Color.FromArgb(0, 153, 76)\n    RED        = Drawing.Color.FromArgb(160, 50, 50)\n    MID_GREY   = Drawing.Color.FromArgb(80, 80, 80)\n\n    ROW_H   = 22\n    MAX_VIS = 8\n    N       = len(family_names_with_counts)\n    CLB_H   = min(N, MAX_VIS) * ROW_H + 4\n    FORM_W  = 520\n    INNER_W = FORM_W - 32\n\n    form = WinForms.Form()\n    form.Text            = \"ConMan Part 2 — Connector Options\"\n    form.Width           = FORM_W\n    form.StartPosition   = WinForms.FormStartPosition.CenterScreen\n    form.FormBorderStyle = WinForms.FormBorderStyle.FixedDialog\n    form.MaximizeBox     = False\n    form.MinimizeBox     = False\n    form.BackColor       = DARK_BG\n\n    y = 14\n\n    def add_label(text, font_size, bold, color, y_pos, height=20, indent=16):\n        lbl           = WinForms.Label()\n        lbl.Text      = text\n        lbl.ForeColor = color\n        lbl.Font      = Drawing.Font(\n            DEF_FONT, font_size,\n            Drawing.FontStyle.Bold if bold else Drawing.FontStyle.Regular\n        )\n        lbl.Location = Drawing.Point(indent, y_pos)\n        lbl.Size     = Drawing.Size(INNER_W, height)\n        form.Controls.Add(lbl)\n\n    def add_separator(y_pos):\n        sep           = WinForms.Panel()\n        sep.BackColor = DIVIDER\n        sep.Location  = Drawing.Point(16, y_pos)\n        sep.Size      = Drawing.Size(INNER_W, 1)\n        form.Controls.Add(sep)\n\n    def add_section_header(text, y_pos):\n        bg           = WinForms.Panel()\n        bg.BackColor = SECTION_BG\n        bg.Location  = Drawing.Point(0, y_pos)\n        bg.Size      = Drawing.Size(FORM_W, 28)\n        form.Controls.Add(bg)\n        lbl           = WinForms.Label()\n        lbl.Text      = text\n        lbl.ForeColor = WHITE\n        lbl.Font      = Drawing.Font(DEF_FONT, 9, Drawing.FontStyle.Bold)\n        lbl.Location  = Drawing.Point(12, 5)\n        lbl.Size      = Drawing.Size(INNER_W, 18)\n        lbl.BackColor = Drawing.Color.Transparent\n        bg.Controls.Add(lbl)\n        return y_pos + 28\n\n    def add_clb(y_pos):\n        clb              = WinForms.CheckedListBox()\n        clb.Location     = Drawing.Point(16, y_pos)\n        clb.Width        = INNER_W\n        clb.Height       = CLB_H\n        clb.BackColor    = DARKER_BG\n        clb.ForeColor    = WHITE\n        clb.Font         = Drawing.Font(DEF_FONT, 9)\n        clb.BorderStyle  = getattr(WinForms.BorderStyle, \"None\")\n        clb.CheckOnClick = True\n        for fam_name, count in family_names_with_counts:\n            clb.Items.Add(\"  {} ({} in model)\".format(fam_name, count), False)\n        form.Controls.Add(clb)\n        return clb\n\n    def add_all_none_buttons(y_pos, target_clb):\n        def on_all(s, e):\n            for i in range(target_clb.Items.Count):\n                target_clb.SetItemChecked(i, True)\n        def on_none(s, e):\n            for i in range(target_clb.Items.Count):\n                target_clb.SetItemChecked(i, False)\n\n        for label, x_pos, color, handler in [\n            (\"All\",  16,  BLUE,     on_all),\n            (\"None\", 94,  MID_GREY, on_none),\n        ]:\n            btn                           = WinForms.Button()\n            btn.Text                      = label\n            btn.Location                  = Drawing.Point(x_pos, y_pos)\n            btn.Size                      = Drawing.Size(70, 24)\n            btn.FlatStyle                 = WinForms.FlatStyle.Flat\n            btn.BackColor                 = color\n            btn.ForeColor                 = WHITE\n            btn.Font                      = Drawing.Font(DEF_FONT, 8)\n            btn.FlatAppearance.BorderSize = 0\n            btn.Click                    += handler\n            form.Controls.Add(btn)\n        return y_pos + 30\n\n    # — Section 1: MOVE ────────────────────────────────────────────────────────\n    y = add_section_header(\"  ↕  MOVE — Reposition connectors to their Data Cube?\", y)\n    add_label(\"Checked families will be repositioned. Unchecked stay in place.\", 8, False, GREY, y + 4, height=16)\n    y += 22\n    clb_move = add_clb(y)\n    y += CLB_H + 4\n    y = add_all_none_buttons(y, clb_move)\n\n    add_separator(y + 4)\n    y += 14\n\n    # — Section 2: UPDATE ──────────────────────────────────────────────────────\n    y = add_section_header(\"  ✎  UPDATE — Write Utility Matrix data to Revit parameters?\", y)\n    add_label(\"Checked families will have parameters written from the Matrix. Unchecked are skipped.\", 8, False, GREY, y + 4, height=16)\n    y += 22\n    clb_update = add_clb(y)\n    y += CLB_H + 4\n    y = add_all_none_buttons(y, clb_update)\n\n    add_separator(y + 4)\n    y += 14\n\n    # — Run / Cancel ───────────────────────────────────────────────────────────\n    for label, x_pos, width, color, dr in [\n        (\"Run\",    16,  230,           GREEN, WinForms.DialogResult.OK),\n        (\"Cancel\", 254, FORM_W - 270,  RED,   WinForms.DialogResult.Cancel),\n    ]:\n        btn                           = WinForms.Button()\n        btn.Text                      = label\n        btn.Location                  = Drawing.Point(x_pos, y)\n        btn.Size                      = Drawing.Size(width, 36)\n        btn.FlatStyle                 = WinForms.FlatStyle.Flat\n        btn.BackColor                 = color\n        btn.ForeColor                 = WHITE\n        btn.Font                      = Drawing.Font(\n            DEF_FONT, 10,\n            Drawing.FontStyle.Bold if label == \"Run\" else Drawing.FontStyle.Regular\n        )\n        btn.FlatAppearance.BorderSize = 0\n        btn.DialogResult              = dr\n        form.Controls.Add(btn)\n        if label == \"Run\":    form.AcceptButton = btn\n        if label == \"Cancel\": form.CancelButton = btn\n\n    form.Height = y + 36 + 52\n    dialog_result = form.ShowDialog()\n\n    if dialog_result != WinForms.DialogResult.OK:\n        return None, None\n\n    move_sel = {\n        family_names_with_counts[i][0]\n        for i in range(clb_move.Items.Count)\n        if clb_move.GetItemChecked(i)\n    }\n    update_sel = {\n        family_names_with_counts[i][0]\n        for i in range(clb_update.Items.Count)\n        if clb_update.GetItemChecked(i)\n    }\n    return move_sel, update_sel\n\n\nsorted_families = sorted(family_count.items(), key=lambda x: x[0])\n\nif sorted_families:\n    moveable_families, update_families = show_family_selection_dialog(sorted_families)\n    if moveable_families is None:\n        OUT = [[\"Cancelled by user.\"]], [[\"Key Value\", \"Status\"]], [], []\n        sys.exit()\nelse:\n    moveable_families = set()\n    update_families   = set()\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 7 — DATA CUBE LOOKUP\n#\n#   Collects all \"Process Data Cube - Generic\" instances and builds a dict:\n#     Equipment ID (uppercase) → Revit element\n#   Used by Move Logic to determine the target world-space location for\n#   each connector being repositioned.\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndata_cubes = [\n    c for c in (\n        FilteredElementCollector(doc)\n        .OfCategory(BuiltInCategory.OST_GenericModel)\n        .WhereElementIsNotElementType()\n        .ToElements()\n    )\n    if c.Symbol and \"Process Data Cube - Generic\" in c.Symbol.Family.Name\n]\n\ncube_lookup = {}\nfor cube in data_cubes:\n    eid = get_param_value(cube, \"Equipment ID\")\n    if eid:\n        cube_lookup[str(eid).strip().upper()] = cube\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 8 — MOVE LOGIC\n#\n#   For each Equipment ID that has connectors in a selected Move family:\n#     1. Looks up its parent Data Cube element by Equipment ID.\n#     2. Reads the cube's Offset Front/Back/Left/Right/Top parameters to\n#        determine the connector placement region in local cube space.\n#     3. Distributes connectors evenly along the cube's longest horizontal axis.\n#     4. Transforms computed local points to world space via the cube transform.\n#     5. Sets each connector's LocationPoint to its computed world position.\n#   Connectors whose family is not in the Move selection are logged as Skipped.\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef set_location(elem, new_xyz):\n    \"\"\"Moves elem to new_xyz if it isn't already there. Returns (moved: bool, old_loc_str).\"\"\"\n    try:\n        loc = elem.Location\n        if isinstance(loc, LocationPoint):\n            old_pt  = loc.Point\n            old_str = \"X:{:.2f}, Y:{:.2f}, Z:{:.2f}\".format(old_pt.X, old_pt.Y, old_pt.Z)\n            if not old_pt.IsAlmostEqualTo(new_xyz, 0.0026):\n                loc.Point = new_xyz\n                return True, old_str\n            return False, old_str\n        return False, \"N/A\"\n    except:\n        return False, \"Error\"\n\nmove_report = []  # Each row: [elem_id, conn_id, equip_id, action, old_loc, new_loc]\n\nif moveable_families:\n    # Group connectors by Equipment ID for spacing calculation\n    conns_by_eid = {}\n    for ec in existing_connectors:\n        eid = get_param_value(ec, \"Equipment ID\")\n        if eid:\n            conns_by_eid.setdefault(str(eid).strip().upper(), []).append(ec)\n\n    TransactionManager.Instance.EnsureInTransaction(doc)\n\n    for eid_key, conns in conns_by_eid.items():\n        cube = cube_lookup.get(eid_key)\n        if not cube:\n            continue\n\n        # Read Data Cube offset parameters (Revit internal units = feet)\n        f  = get_param_value(cube, \"Offset Front\") or 0.0\n        bk = get_param_value(cube, \"Offset Back\")  or 0.0\n        l  = get_param_value(cube, \"Offset Left\")  or 0.0\n        r  = get_param_value(cube, \"Offset Right\") or 0.0\n        t  = get_param_value(cube, \"Offset Top\")   or 0.0\n\n        length_dim = abs(f) + abs(bk)\n        width_dim  = abs(l) + abs(r)\n        lx         = (r - l) / 2.0\n        ly         = (f - bk) / 2.0\n        lz         = t\n\n        total_n      = len(conns)\n        is_len       = length_dim >= width_dim\n        axis_dim     = length_dim if is_len else width_dim\n        spacing      = max(0.333, axis_dim / (total_n + 1))\n        start_offset = -((total_n - 1) * spacing) / 2.0\n        trans        = cube.GetTransform()\n\n        for i, ec in enumerate(conns):\n            fn      = get_family_name(ec)\n            conn_id = get_param_value(ec, \"Connection ID\") or \"\"\n            eid_raw = get_param_value(ec, \"Equipment ID\") or eid_key\n\n            step     = start_offset + (i * spacing)\n            local_pt = XYZ(lx, ly + step, lz) if is_len else XYZ(lx + step, ly, lz)\n            world_pt = trans.OfPoint(local_pt)\n            new_loc  = \"X:{:.2f}, Y:{:.2f}, Z:{:.2f}\".format(world_pt.X, world_pt.Y, world_pt.Z)\n\n            if fn in moveable_families:\n                moved, old_loc = set_location(ec, world_pt)\n                action = \"Moved\" if moved else \"No Change\"\n            else:\n                loc = ec.Location\n                old_loc = (\n                    \"X:{:.2f}, Y:{:.2f}, Z:{:.2f}\".format(loc.Point.X, loc.Point.Y, loc.Point.Z)\n                    if isinstance(loc, LocationPoint) else \"N/A\"\n                )\n                action  = \"Skipped (Family Not Selected)\"\n                new_loc = old_loc\n\n            move_report.append([str(ec.Id), conn_id, str(eid_raw), action, old_loc, new_loc])\n\n    TransactionManager.Instance.TransactionTaskDone()\n    doc.Regenerate()\n\n# Build Connection ID (upper) → move action and locations for use in write report\nmove_action_lookup = {\n    str(r[1]).strip().upper(): r[3]\n    for r in move_report if len(r) >= 4\n}\nmove_loc_lookup = {\n    str(r[1]).strip().upper(): (r[4], r[5])  # (old_loc, new_loc)\n    for r in move_report if len(r) >= 6\n}\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 9 — PARAMETER WRITE LOGIC\n#\n#   For each row in the Excel flat data:\n#     1. Match to a Revit connector element by Connection ID.\n#     2. Skip the element if its family is not in update_families.\n#     3. For each Excel column:\n#          a. Look up the Revit parameter name(s) in the UM-Revit Mapping.\n#          b. Check family applicability — skip if mapping says \"No\" for this family.\n#          c. Skip columns with empty / null / \"-\" Excel values.\n#          d. For instance parameters: write directly via compare_and_set_param.\n#          e. For type parameters: iterate family symbols to find a matching type\n#             (handles Voltage & Phase → Family Type swap).\n#\n#   Report header:\n#     [Revit Element ID] [Connection ID] [Family] [Update Status] [Moved]\n#     [Original: <col>] [Updated: <col>]  ← one pair per writable Excel column\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef write_parameters_to_revit(data_input, key_param_name, file_path):\n    data = extract_flat_data(data_input)\n    if not data or not key_param_name:\n        return [[\"Error: Inputs are empty.\"]], [], 0, 0\n\n    # Load UM-Revit Mapping (includes family applicability per column)\n    um_revit_map = read_um_revit_mapping(file_path)\n\n    # Build element lookup: Connection ID lowercase → connector element\n    # Use existing_connectors (not all_elements) — Data Cubes and other\n    # non-connector elements can have Connection ID set (Script 1), and if\n    # they land last in iteration they overwrite connector entries in the dict.\n    # The write loop then finds a Data Cube, sees it is not in update_families,\n    # sets update_allowed=False, and writes nothing. Connectors are missed entirely.\n    element_lookup = {}\n    for el in existing_connectors:\n        p = el.LookupParameter(key_param_name)\n        if p:\n            val = get_param_display_value(p)\n            if val:\n                element_lookup[val.strip().lower()] = el\n\n    # Recover display-case column names from extractor mapping metadata\n    col_case_map = {}\n    mapping_entries = safe_get(data_input, \"Mapping\")\n    if mapping_entries:\n        try:\n            for entry in mapping_entries:\n                orig = safe_get(entry, \"Excel Header\") or \"\"\n                if orig:\n                    col_case_map[str(orig).strip().lower()] = str(orig).strip()\n        except:\n            pass\n\n    # Build ordered list of Excel columns to process.\n    # IMPORTANT: restrict to only columns in the explicit mapping list (col_case_map).\n    # The extractor reads ALL sheet columns into each row dict, so raw passthrough\n    # columns (e.g. the bare \"Service\" column when \"Service Abbreviation\" is the\n    # mapped one) would otherwise sneak in here and trigger spurious writes.\n    # Order is preserved from the Mapping list to keep the report column order stable.\n    all_excel_cols = []\n    seen_lower     = set()\n    for mapped_lower, mapped_display in col_case_map.items():\n        if mapped_lower not in seen_lower:\n            seen_lower.add(mapped_lower)\n            all_excel_cols.append(mapped_display)\n\n    key_col_lower  = key_param_name.strip().lower()\n    writable_cols  = [c for c in all_excel_cols if c.strip().lower() != key_col_lower]\n    not_found_keys = set()\n    params_written = 0\n    params_skipped = 0\n\n    # Build report header\n    # \"Original: Location\" / \"Updated: Location\" give the ExcelGen a proper\n    # before/after pair for moves, so the change is visible and highlighted.\n    header_row = [\"Revit Element ID\", \"Connection ID\", \"Family\", \"Update Status\",\n                  \"Moved\", \"Parameters Changed\", \"Original: Location\", \"Updated: Location\"]\n    for col in writable_cols:\n        header_row.extend([\"Original: \" + col, \"Updated: \" + col])\n    processed_report = [header_row]\n\n    TransactionManager.Instance.EnsureInTransaction(doc)\n\n    for data_row in data:\n        key_value = safe_get(data_row, key_col_lower)\n        if key_value is None:\n            continue\n\n        element = element_lookup.get(str(key_value).strip().lower())\n        if not element:\n            not_found_keys.add(key_value)\n            continue\n\n        elem_fn        = get_family_name(element)\n        update_allowed = elem_fn in update_families if update_families else False\n        el_type        = doc.GetElement(element.GetTypeId())\n        conn_id_upper  = str(key_value).strip().upper()\n        moved_status   = move_action_lookup.get(conn_id_upper, \"Not Processed\")\n        old_loc, new_loc = move_loc_lookup.get(conn_id_upper, (\"\", \"\"))\n\n        inst_param_map = build_param_map(element)\n        type_param_map = build_param_map(el_type) if el_type else {}\n\n        element_was_updated = False\n        changed_excel_cols = []\n        values_row = [element.Id.ToString(), str(key_value), elem_fn, \"Unchanged\",\n                      moved_status, \"\", old_loc, new_loc]\n\n        for col in writable_cols:\n            col_lower = col.strip().lower()\n            new_val   = safe_get(data_row, col_lower)\n\n            # — Resolve Revit parameter name(s) and family applicability ──────\n            mapping_entry = um_revit_map.get(col_lower)\n\n            if mapping_entry:\n                revit_param_names   = mapping_entry[\"params\"]\n                applicable_families = mapping_entry[\"families\"]\n            else:\n                # No UM-Revit entry — try direct name match on the element\n                if col_lower in inst_param_map or col_lower in type_param_map:\n                    revit_param_names   = [col]\n                    applicable_families = []  # no restriction\n                else:\n                    values_row.extend([\"\", \"\"])\n                    continue  # Column not found anywhere — skip\n\n            # — Check family applicability ─────────────────────────────────────\n            if applicable_families and not family_is_applicable(elem_fn, applicable_families):\n                # Family not listed in UM-Revit Mapping (e.g. \"Process Data Connector\"\n                # mapped from TD- prefix in Script 1). Fall back: if the mapped\n                # parameter(s) physically exist on this element, allow the write.\n                # Parameter presence is the ground truth — family-specific params\n                # (e.g. Full Load Current on Electrical only) will simply not exist\n                # on unlisted families and will be skipped naturally.\n                param_exists_on_elem = any(\n                    inst_param_map.get(rpn.strip().lower()) is not None or\n                    type_param_map.get(rpn.strip().lower()) is not None\n                    for rpn in revit_param_names\n                )\n                if not param_exists_on_elem:\n                    values_row.extend([\"\", \"\"])\n                    continue  # Param does not exist on element — genuinely not applicable\n                # else: param exists — fall through and write it\n\n            # ─────────────────────────────────────────────────────────────────\n            # Per-column write logic:\n            #\n            #   Step 1 — Pre-read the BEFORE value for every mapped Revit param.\n            #            Done before any write so we always have the true pre-run state.\n            #\n            #   Step 2 — Short-circuit for empty Excel value or unselected family.\n            #            No write, before == after, cell stays white.\n            #\n            #   Step 3 — Write to ALL mapped params. For each one, record whether\n            #            it actually changed (compare_and_set_param is idempotent).\n            #            Track the first param that genuinely changed.\n            #\n            #   Step 4 — Choose display values for the report:\n            #            • If a param changed  → use THAT param's before/after.\n            #              This is critical for multi-param columns (e.g. Connection\n            #              Size → [Nominal Diameter, Connection Size]) where the\n            #              primary Double param may be unchanged while the secondary\n            #              String param was updated. Without this, the report would\n            #              show identical before/after even though Update Status=Updated.\n            #            • If nothing changed  → use primary param's current value\n            #              for both sides so the ExcelGen sees no diff → no highlight.\n            # ─────────────────────────────────────────────────────────────────\n\n            # Step 1 — pre-read before-values for all mapped params\n            param_records = []  # (rpn_lower, param_obj, tp_obj, before_display)\n            for rpn in revit_param_names:\n                rpn_lower = rpn.strip().lower()\n                p  = inst_param_map.get(rpn_lower)\n                tp = type_param_map.get(rpn_lower)\n                before = (get_param_display_value(p)  if p  is not None else\n                          get_param_display_value(tp) if tp is not None else \"\")\n                param_records.append((rpn_lower, p, tp, before))\n\n            # Default display source: first param that exists on this element\n            primary_before = param_records[0][3] if param_records else \"\"\n            any_updated    = False\n\n            # Step 2 — short-circuit: empty Excel value or family not selected\n            if new_val is None or str(new_val).strip() in (\"\", \"-\", \"None\", \"null\"):\n                values_row.extend([primary_before, primary_before])\n                params_skipped += 1\n                continue\n\n            if not update_allowed:\n                values_row.extend([primary_before, primary_before])\n                continue\n\n            # Step 3 — write to all mapped params, track the first actual change\n            first_changed_before = None\n            first_changed_param  = None\n\n            col_was_updated = False\n            for rpn_lower, param_to_set, tp_match, before_display in param_records:\n\n                if param_to_set is not None and not param_to_set.IsReadOnly:\n                    changed, _ = compare_and_set_param(param_to_set, new_val)\n                    if changed:\n                        if first_changed_before is None:\n                            first_changed_before = before_display\n                            first_changed_param  = rpn_lower\n                        any_updated    = True\n                        col_was_updated = True\n                        params_written += 1\n                    else:\n                        params_skipped += 1\n\n                elif tp_match is not None:\n                    # Type parameter — search family symbols for matching type\n                    if check_param_match(tp_match, new_val):\n                        params_skipped += 1\n                    else:\n                        family = el_type.Family\n                        for sym_id in family.GetFamilySymbolIds():\n                            sym    = doc.GetElement(sym_id)\n                            sym_pm = build_param_map(sym)\n                            sym_p  = sym_pm.get(rpn_lower)\n                            if sym_p and check_param_match(sym_p, new_val):\n                                if not sym.IsActive: sym.Activate()\n                                element.ChangeTypeId(sym_id)\n                                if first_changed_before is None:\n                                    first_changed_before = before_display\n                                    first_changed_param  = rpn_lower\n                                any_updated    = True\n                                col_was_updated = True\n                                el_type        = sym\n                                type_param_map = build_param_map(el_type)\n                                params_written += 1\n                                break\n\n            # Step 4 — choose display values for the report\n            if any_updated:\n                element_was_updated = True\n                doc.Regenerate()\n\n            current_type = doc.GetElement(element.GetTypeId())\n            current_inst_param_map = build_param_map(element)\n            current_type_param_map = build_param_map(current_type) if current_type else {}\n            current_display = get_representative_display(\n                revit_param_names,\n                current_inst_param_map,\n                current_type_param_map,\n                preferred_name=first_changed_param,\n            )\n\n            if first_changed_before is not None:\n                original_val_str = first_changed_before\n                final_val_str    = current_display\n            else:\n                original_val_str = primary_before\n                final_val_str    = current_display if str(current_display).strip() != \"\" else primary_before\n\n            if col_was_updated:\n                changed_excel_cols.append(col)\n\n            values_row.extend([original_val_str, final_val_str])\n\n        if element_was_updated:\n            values_row[3] = \"Updated\"\n        values_row[5] = \", \".join(changed_excel_cols)\n\n        processed_report.append(values_row)\n\n    TransactionManager.Instance.TransactionTaskDone()\n\n    not_found_report = [[\"Key Value\", \"Status\"]]\n    for key in sorted(not_found_keys):\n        not_found_report.append([key, \"Element Not Found in Revit\"])\n\n    if len(processed_report) <= 1:\n        processed_report = [[\"No matching elements were found to process.\"]]\n\n    return processed_report, not_found_report, params_written, params_skipped\n\n\nparam_results = write_parameters_to_revit(extractor_output, key_parameter, excel_file_path)\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 10 — OUTPUT ASSEMBLY\n#\n#   OUT[0] — Connector update report  → ExcelGen \"Connector Updates\" sheet\n#            List-of-lists. Header row, then one row per matched connector.\n#            Columns: Revit Element ID, Connection ID, Family, Update Status,\n#                     Moved, then Original/Updated pairs for each Excel column.\n#\n#   OUT[1] — Not-found report         → ExcelGen \"Metrics\" sheet\n#            List-of-lists. Connectors whose Connection ID had no Revit match.\n#\n#   OUT[2] — Move detail report       → Watch node / optional downstream use\n#            List of rows: [elem_id, conn_id, equip_id, action, old_loc, new_loc]\n#\n#   OUT[3] — Run metrics summary      → optional Watch node\n#            Key/value summary of counts for the run.\n# ═══════════════════════════════════════════════════════════════════════════════\n\nmoved_count  = sum(1 for r in move_report if r[3] == \"Moved\")\nno_chg_count = sum(1 for r in move_report if r[3] == \"No Change\")\nskip_fam     = sum(1 for r in move_report if r[3] == \"Skipped (Family Not Selected)\")\n\nmove_metrics = [\n    [\"Metric\",                                            \"Value\"],\n    [\"Total Connectors Scanned\",                          str(len(existing_connectors))],\n    [\"Families Selected for Move\",                        str(len(moveable_families))],\n    [\"Families Selected for Update\",                      str(len(update_families))],\n    [\"Connectors Moved\",                                  str(moved_count)],\n    [\"Connectors Already In Place\",                       str(no_chg_count)],\n    [\"Connectors Skipped (Family Not Selected for Move)\", str(skip_fam)],\n    [\"Parameters Written\",                                str(param_results[2]) if len(param_results) > 2 else \"N/A\"],\n    [\"Parameters Already Matched / Skipped\",              str(param_results[3]) if len(param_results) > 3 else \"N/A\"],\n]\n\nOUT = [param_results[0], param_results[1], move_report, move_metrics]\n",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
