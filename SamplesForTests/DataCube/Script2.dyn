    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# ExcelGen\n# Excel Report Generator\n# Revit 2023 / Dynamo 2.16 / CPython3\n# Developed By - Chris Staker\n# v1.9.3 - Fixed Moved cell false-positive highlight:\n#            Moved cell now only turns yellow when connector was actually Moved.\n#            Previously, Moved cell was yellow on ANY row change (param write or move).\n#          - Removed Moved from anchor col set; handled per-cell with row_was_moved check.\n#          - Connection ID + Original/Updated Equipment ID: yellow on any row change.\n#          - All other changed Original/Updated pairs: yellow via changed_cols.\n#          - Everything else: explicit white.\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 1 — CONFIGURATION CONSTANTS\n# ═══════════════════════════════════════════════════════════════════════════════\n\nDEPENDENCY_FOLDER_NAME = \"Python Support Pckg\"\nLOCAL_LIBRARY_PATH     = r\"C:\\Dynamo\\2.16\\Python Support Pckg\"\nNETWORK_LIBRARY_PATH   = r\"K:\\CAD\\_Revit2023\\Add_Ins\\Python Support Pckg\"\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 2 — STANDARD LIBRARY IMPORTS & LOGGER\n# ═══════════════════════════════════════════════════════════════════════════════\n\nimport sys\nimport os\nimport platform\nimport time\nfrom datetime import datetime\nfrom pathlib import Path\nimport re\nimport traceback\nimport colorsys\n\n\nclass Logger:\n    def __init__(self):\n        self.messages  = []\n        self.start_time = time.time()\n\n    def _record(self, message, level):\n        timestamp = datetime.now().strftime(\"%H:%M:%S\")\n        elapsed   = round(time.time() - self.start_time, 2)\n        try:\n            msg_str = str(message).encode('utf-8', 'replace').decode('utf-8')\n            self.messages.append(\"[{}][{}s][{}] {}\".format(timestamp, elapsed, level, msg_str))\n        except Exception:\n            self.messages.append(\"[{}][{}s][ERROR] Error formatting log message.\".format(timestamp, elapsed))\n\n    def log(self, message):     self._record(message, \"INFO\")\n    def error(self, message):   self._record(message, \"ERROR\")\n    def warning(self, message): self._record(message, \"WARN\")\n    def get_messages(self):     return self.messages\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 3 — DEPENDENCY PATH SETUP\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef setup_library_paths(logger):\n    logger.log(\"--- Running Dependency Check ---\")\n    for path, label in [(LOCAL_LIBRARY_PATH, \"Local C Drive\"), (NETWORK_LIBRARY_PATH, \"Network Drive\")]:\n        logger.log(\"Checking {} for libraries...\".format(label))\n        if os.path.isdir(path):\n            logger.log(\"Found library path on {}: {}\".format(label, path))\n            if path not in sys.path:\n                sys.path.insert(0, path)\n            return True, path, label\n    logger.error(\"FAILURE: Could not find the required library folder.\")\n    return False, None, None\n\n\nlogger   = Logger()\nlogger.log(\"ExcelGen v1.8.0 Started\")\npath_found, found_path, location_name = setup_library_paths(logger)\n\nif not path_found:\n    OUT = [\"FATAL ERROR: Could not find 'openpyxl' library.\", logger.get_messages(), \"0\"]\nelse:\n    try:\n        import openpyxl\n        from openpyxl.styles import PatternFill, Font, Alignment\n        from openpyxl.utils import get_column_letter\n        from openpyxl.worksheet.table import Table, TableStyleInfo\n        logger.log(\"Successfully imported 'openpyxl' from {}.\".format(location_name))\n    except ImportError as e:\n        OUT = [\"FATAL ERROR: Import failed from '{}'. Details: {}\".format(found_path, e),\n               logger.get_messages(), \"0\"]\n    else:\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 4 — CONSTANTS & THEME HELPERS\n# ═══════════════════════════════════════════════════════════════════════════════\n\n        MAX_SHEET_NAME_LENGTH = 31\n        MAX_COLUMN_WIDTH      = 120\n\n        # Highlighting colors\n        CHANGED_COLOR_A = \"FFFFFF99\"  # Soft yellow — changed rows (even)\n        CHANGED_COLOR_B = \"FFFFFFCC\"  # Lighter yellow — changed rows (odd)\n        BASE_TABLE_STYLE = \"TableStyleMedium2\"\n\n        def create_theme_shades(hex_color):\n            try:\n                hex_color = hex_color.lstrip('#')\n                r, g, b   = (int(hex_color[i:i+2], 16) / 255.0 for i in (0, 2, 4))\n                h, l, s   = colorsys.rgb_to_hls(r, g, b)\n                # Summary block: lighter shade of theme color\n                sum_l      = l + (1 - l) * 0.70\n                sr, sg, sb = [int(c * 255) for c in colorsys.hls_to_rgb(h, sum_l, s)]\n                # Stripe shade (used by Simple reports)\n                str_l      = l + (1 - l) * 0.90\n                str_s      = s * 0.5\n                xr, xg, xb = [int(c * 255) for c in colorsys.hls_to_rgb(h, str_l, str_s)]\n                return {\n                    \"summary\": \"FF{:02X}{:02X}{:02X}\".format(sr, sg, sb),\n                    \"stripe\":  \"FF{:02X}{:02X}{:02X}\".format(xr, xg, xb),\n                }\n            except Exception:\n                return {\"summary\": \"FFF0F0F0\", \"stripe\": \"FFF9F9F9\"}\n\n        def get_theme_config(theme_input, logger):\n            THEMES = {\n                \"blue\": \"4472C4\", \"green\": \"70AD47\", \"red\": \"C5504B\",\n                \"purple\": \"7030A0\", \"orange\": \"ED7D31\", \"teal\": \"264653\"\n            }\n            theme_str = str(theme_input).lower().strip() if theme_input else \"blue\"\n            hex_color = THEMES.get(theme_str)\n            if not hex_color:\n                hex_color = theme_str.lstrip('#')\n                if not (len(hex_color) == 6 and all(c in '0123456789abcdef' for c in hex_color)):\n                    logger.warning(\"Invalid theme '{}'. Using 'blue'.\".format(theme_str))\n                    hex_color = THEMES[\"blue\"]\n            shades = create_theme_shades(hex_color)\n            return {\n                \"header_color\":       \"FF\" + hex_color.upper(),\n                \"summary_background\": shades[\"summary\"],\n                \"stripe_background\":  shades[\"stripe\"],\n                \"log_header_color\":   \"FF\" + hex_color.upper(),\n            }\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 5 — HELPER FUNCTIONS\n# ═══════════════════════════════════════════════════════════════════════════════\n\n        def safe_cell_value(value):\n            if value is None: return \"\"\n            try:    str_value = str(value)\n            except: str_value = repr(value)\n            str_value = re.sub(r'[\\x00-\\x08\\x0B\\x0C\\x0E-\\x1F\\x7F]', '', str_value)\n            return str_value[:32767]\n\n        def create_safe_table_name(sheet_name):\n            safe_name = re.sub(r'[^\\w]', '', sheet_name)\n            if not safe_name or not safe_name[0].isalpha():\n                safe_name = \"Table\" + safe_name\n            return safe_name[:250] + \"Data\"\n\n        def should_center_align(value):\n            if value is None or value == \"\": return True\n            return len(str(value).strip()) <= 35\n\n        def validate_filepath(filepath, logger):\n            is_valid = False\n            if filepath and isinstance(filepath, str) and filepath.strip():\n                filepath = filepath.strip()\n                dir_name = os.path.dirname(filepath)\n                if dir_name and os.path.isdir(dir_name):\n                    is_valid = True\n                    logger.log(\"Using provided filepath: '{}'\".format(filepath))\n            if not is_valid:\n                logger.log(\"Creating default save path on Desktop...\")\n                try:\n                    home_dir     = os.path.expanduser(\"~\")\n                    desktop_path = os.path.join(home_dir, \"Desktop\")\n                    for item in os.listdir(home_dir):\n                        if \"onedrive\" in item.lower():\n                            od = os.path.join(home_dir, item, \"Desktop\")\n                            if os.path.isdir(od):\n                                desktop_path = od\n                                break\n                    base_name = (os.path.basename(filepath.strip())\n                                 if filepath and isinstance(filepath, str) and filepath.strip()\n                                 else \"\")\n                    if not base_name:\n                        base_name = \"Multi_Sheet_Report_{}.xlsx\".format(\n                            datetime.now().strftime('%Y%m%d_%H%M%S'))\n                    if not base_name.lower().endswith('.xlsx'):\n                        base_name = os.path.splitext(base_name)[0] + \".xlsx\"\n                    filepath = os.path.join(desktop_path, base_name)\n                    logger.log(\"Generated Desktop path: {}\".format(filepath))\n                except Exception as e:\n                    logger.error(\"Could not create default path: {}\".format(e))\n                    return False, None, True\n            if not filepath.lower().endswith('.xlsx'):\n                filepath += '.xlsx'\n            return True, filepath, not is_valid\n\n        def validate_sheet_name(sheet_name, logger):\n            if not sheet_name:\n                return \"Report Sheet\"\n            sheet_name = re.sub(r'[\\\\/?*\\[\\]:]', '_', str(sheet_name)).strip(\"'\\\"\")\n            if len(sheet_name) > MAX_SHEET_NAME_LENGTH:\n                sheet_name = sheet_name[:MAX_SHEET_NAME_LENGTH]\n                logger.warning(\"Sheet name truncated to {} chars.\".format(MAX_SHEET_NAME_LENGTH))\n            return sheet_name\n\n        def normalize_data_package(package, logger):\n            \"\"\"Converts any supported data shape to (headers_list, columns_list, error).\"\"\"\n            # List of lists (table format — primary format from parameter writer)\n            if (isinstance(package, list) and len(package) > 0 and\n                    all(isinstance(row, list) for row in package)):\n                logger.log(\"Detected list-of-lists (table) format.\")\n                headers    = package[0]\n                data_rows  = package[1:]\n                n_headers  = len(headers)\n                sanitized  = []\n                for i, row in enumerate(data_rows):\n                    n = len(row)\n                    if n < n_headers:\n                        sanitized.append(row + [''] * (n_headers - n))\n                    elif n > n_headers:\n                        sanitized.append(row[:n_headers])\n                    else:\n                        sanitized.append(row)\n                if not sanitized:\n                    return headers, [[] for _ in headers], None\n                data_columns = list(map(list, zip(*sanitized)))\n                return headers, data_columns, None\n\n            # Legacy [headers_list, data_dict]\n            if (isinstance(package, list) and len(package) == 2 and\n                    isinstance(package[0], list) and isinstance(package[1], dict)):\n                logger.log(\"Detected legacy [headers, dict] format.\")\n                headers      = package[0]\n                data_columns = [package[1].get(h, []) for h in headers]\n                return headers, data_columns, None\n\n            # Column-oriented dict\n            if isinstance(package, dict):\n                logger.log(\"Detected column-oriented dict format.\")\n                if not package: return [], [], None\n                headers      = list(package.keys())\n                data_columns = [v if isinstance(v, list) else [v] for v in package.values()]\n                return headers, data_columns, None\n\n            # Row-oriented list of dicts\n            if isinstance(package, list) and (not package or all(isinstance(i, dict) for i in package)):\n                logger.log(\"Detected row-oriented list-of-dicts format.\")\n                if not package: return [], [], None\n                ordered_headers = []\n                header_set      = set()\n                for row in package:\n                    for key in row.keys():\n                        if key not in header_set:\n                            header_set.add(key)\n                            ordered_headers.append(key)\n                data_columns = [[row.get(h) for row in package] for h in ordered_headers]\n                return ordered_headers, data_columns, None\n\n            # Simple list\n            if isinstance(package, list):\n                logger.log(\"Detected simple list format.\")\n                return [\"Value\"], [package], None\n\n            err = \"Data package has an unrecognized format or is null.\"\n            logger.error(err)\n            return None, None, err\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 6 — COMPARISON REPORT DATA PROCESSOR\n#\n#   Identifies \"Original:\" / \"Updated:\" column pairs, compares values row by row,\n#   and returns per-row change metadata alongside aggregate statistics.\n# ═══════════════════════════════════════════════════════════════════════════════\n\n        def process_comparison_data(data_columns, headers, logger):\n            \"\"\"\n            Processes the writer's report (list-of-columns) to identify which\n            Original/Updated cell pairs actually changed.\n\n            Returns:\n              report_data — list of {data, changed, changed_cols} per row\n                            data rows are NOT modified (no extra column appended)\n              stats       — {total, changed, no_change, errors}\n\n            has_changed is sourced from the writer's \"Update Status\" column\n            (\"Updated\" / \"Unchanged\") which is authoritative. changed_cols\n            tracks which 0-based column indices hold changed Original/Updated\n            values so ExcelGen can highlight exactly those cells.\n            \"\"\"\n            report_data = []\n            stats       = {\"total\": 0, \"changed\": 0, \"no_change\": 0, \"errors\": 0}\n            if not data_columns or not any(data_columns):\n                return report_data, stats\n\n            # Locate the writer's authoritative status columns\n            update_status_idx = next(\n                (i for i, h in enumerate(headers)\n                 if str(h).strip().lower() == 'update status'),\n                None\n            )\n            params_changed_idx = next(\n                (i for i, h in enumerate(headers)\n                 if str(h).strip().lower() == 'parameters changed'),\n                None\n            )\n\n            # Build Original/Updated column index pairs from header names\n            original_cols, updated_cols = {}, {}\n            for idx, header in enumerate(headers):\n                h_lower = str(header).lower()\n                for prefix in ('original:', 'original '):\n                    if h_lower.startswith(prefix):\n                        original_cols[h_lower[len(prefix):].strip()] = idx\n                for prefix in ('updated:', 'updated '):\n                    if h_lower.startswith(prefix):\n                        updated_cols[h_lower[len(prefix):].strip()] = idx\n\n            comparison_pairs = [\n                (original_cols[k], updated_cols[k])\n                for k in original_cols if k in updated_cols\n            ]\n\n            n_rows = len(data_columns[0]) if data_columns and data_columns[0] else 0\n            for i in range(n_rows):\n                stats[\"total\"] += 1\n                try:\n                    row_data = [(col[i] if i < len(col) else \"\") for col in data_columns]\n\n                    # Find changed Original/Updated pairs.\n                    # A pair is \"changed\" only when the values genuinely differ AND\n                    # it's not just two empty strings (non-applicable column for this family).\n                    changed_pair_indices = set()\n                    for orig_idx, upd_idx in comparison_pairs:\n                        orig_val = str(row_data[orig_idx]).strip()\n                        upd_val  = str(row_data[upd_idx]).strip()\n                        if orig_val == upd_val:\n                            continue  # identical — no change\n                        if orig_val == \"\" and upd_val == \"\":\n                            continue  # both empty — column not applicable to this family\n                        changed_pair_indices.add(orig_idx)\n                        changed_pair_indices.add(upd_idx)\n\n                    # Also trust the writer's authoritative \"Parameters Changed\"\n                    # list so the highlight remains correct even when the visible\n                    # before/after strings normalize to the same display text.\n                    if params_changed_idx is not None and params_changed_idx < len(row_data):\n                        changed_names = [\n                            name.strip().lower()\n                            for name in str(row_data[params_changed_idx]).split(',')\n                            if str(name).strip()\n                        ]\n                        for changed_name in changed_names:\n                            if changed_name in original_cols and changed_name in updated_cols:\n                                changed_pair_indices.add(original_cols[changed_name])\n                                changed_pair_indices.add(updated_cols[changed_name])\n\n                    # has_changed drives anchor highlighting and the stats counter.\n                    # Use the writer's authoritative columns: Update Status and Moved.\n                    was_updated = (update_status_idx is not None and\n                                   str(row_data[update_status_idx]).strip() == \"Updated\")\n                    moved_idx_  = next(\n                        (i for i, h in enumerate(headers) if str(h).strip().lower() == 'moved'),\n                        None\n                    )\n                    was_moved   = (moved_idx_ is not None and\n                                   str(row_data[moved_idx_]).strip() == \"Moved\")\n                    has_changed = was_updated or was_moved\n\n                    stats[\"changed\" if has_changed else \"no_change\"] += 1\n                    # Do NOT append any extra column — row_data stays exactly as received\n                    report_data.append({\n                        'data':         row_data,\n                        'changed':      has_changed,\n                        'changed_cols': changed_pair_indices,\n                    })\n                except Exception as e:\n                    stats[\"errors\"] += 1\n                    logger.error(\"Error processing row {}: {}\".format(i, e))\n                    report_data.append({'data': [], 'changed': False, 'changed_cols': set()})\n\n            logger.log(\"Comparison processing done: {}\".format(stats))\n            return report_data, stats\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 7 — SHEET CREATOR\n#\n#   Creates and formats a single worksheet. Handles three report types:\n#\n#   Comparison  — Connector Updates style.\n#                 • Summary block (rows 1-6) with run stats.\n#                 • Data table starting at row 8.\n#                 • Pin columns (ID, Connection ID, Family, Status, Moved):\n#                   always light theme tint.\n#                 • Changed Original/Updated pairs: soft yellow.\n#                 • All other data cells: explicit white.\n#\n#   Simple      — Key/value or plain table. Optional summary header block.\n#                 Alternating row striping.\n#\n#   Error       — Placeholder sheet written when data is null/invalid.\n# ═══════════════════════════════════════════════════════════════════════════════\n\n        def process_and_create_sheet(wb, sheet_config, logger, used_table_names,\n                                     theme_config, total_changed_counter):\n            validated_name = \"\"\n            try:\n                config_name  = sheet_config.get('name', 'Report Sheet')\n                report_type  = sheet_config.get('type')\n                validated_name = validate_sheet_name(config_name, logger)\n                logger.log(\"--- Processing Sheet: '{}' (Type: {}) ---\".format(\n                    validated_name, report_type or 'Unknown'))\n                ws = wb.create_sheet(title=validated_name)\n\n                # ── Error placeholder ─────────────────────────────────────────\n                if report_type == 'Error':\n                    ws['A1'] = \"Data Error\"\n                    ws['A1'].font = Font(bold=True, size=16, color=\"C00000\")\n                    ws['A2'] = sheet_config.get('error_message', 'Unspecified error.')\n                    ws.column_dimensions['A'].width = 100\n                    ws['A2'].alignment = Alignment(wrap_text=True, vertical='top')\n                    return True\n\n                data_headers = sheet_config.get('headers', [])\n                data_columns = sheet_config.get('columns', [])\n\n                # Build fill/font palettes\n                fills = {\n                    \"header\":  PatternFill(start_color=theme_config['header_color'],      fill_type='solid'),\n                    \"summary\": PatternFill(start_color=theme_config['summary_background'], fill_type='solid'),\n                    \"stripe\":  PatternFill(start_color=theme_config['stripe_background'],  fill_type='solid'),\n                    \"white\":   PatternFill(start_color=\"FFFFFFFF\",                        fill_type='solid'),\n                }\n                fonts = {\n                    \"header\": Font(bold=True, color=\"FFFFFF\"),\n                    \"bold\":   Font(bold=True),\n                    \"italic\": Font(italic=True),\n                }\n                center_align = Alignment(horizontal='center', vertical='center')\n                right_align  = Alignment(horizontal='right',  vertical='center')\n\n                # ── Simple report ─────────────────────────────────────────────\n                if report_type == 'Simple':\n                    summary_header_data = sheet_config.get('summary_header')\n                    start_col   = 2 if summary_header_data else 1\n                    data_start  = 8 if summary_header_data else 1\n\n                    if summary_header_data:\n                        title_cell = ws.cell(row=1, column=1, value=\"Execution Summary\")\n                        title_cell.font      = fonts['bold']\n                        title_cell.alignment = center_align\n                        ws.merge_cells(start_row=1, start_column=1, end_row=1, end_column=2)\n                        for r_idx, (key, value) in enumerate(summary_header_data.items(), 2):\n                            ws.cell(row=r_idx, column=1, value=key).font = fonts['bold']\n                            ws.cell(row=r_idx, column=2, value=safe_cell_value(value))\n                        for row in ws.iter_rows(min_row=1,\n                                                max_row=len(summary_header_data) + 1,\n                                                min_col=1, max_col=2):\n                            for cell in row: cell.fill = fills['summary']\n\n                    if data_headers:\n                        for i, value in enumerate(data_headers, start_col):\n                            c           = ws.cell(row=data_start, column=i, value=value)\n                            c.font      = fonts['header']\n                            c.fill      = fills['header']\n                            c.alignment = center_align\n\n                        n_rows = len(data_columns[0]) if data_columns and data_columns[0] else 0\n                        for i in range(n_rows):\n                            for j, col in enumerate(data_columns, start_col):\n                                cell_value  = safe_cell_value(col[i] if i < len(col) else \"\")\n                                cell        = ws.cell(row=data_start + 1 + i, column=j, value=cell_value)\n                                if should_center_align(cell_value):\n                                    cell.alignment = center_align\n\n                        end_col = start_col + len(data_headers) - 1\n                        if n_rows > 0:\n                            for i, row_obj in enumerate(ws.iter_rows(\n                                    min_row=data_start + 1, max_row=data_start + n_rows,\n                                    min_col=start_col, max_col=end_col)):\n                                if (i + 1) % 2 == 0:\n                                    for cell in row_obj: cell.fill = fills['stripe']\n\n                        range_str      = \"{}{}:{}{}\".format(\n                            get_column_letter(start_col), data_start,\n                            get_column_letter(end_col), data_start + n_rows)\n                        safe_tbl_name  = create_safe_table_name(validated_name)\n                        tbl            = Table(displayName=safe_tbl_name, ref=range_str)\n                        tbl.tableStyleInfo = TableStyleInfo(\n                            name=BASE_TABLE_STYLE,\n                            showFirstColumn=False, showLastColumn=False,\n                            showRowStripes=False,  showColumnStripes=False)\n                        ws.add_table(tbl)\n\n                # ── Comparison report ─────────────────────────────────────────\n                elif report_type == 'Comparison':\n                    report_data, stats = process_comparison_data(data_columns, data_headers, logger)\n                    # report_headers = data_headers exactly — writer already includes\n                    # \"Update Status\" at position 3. Do NOT append a duplicate column.\n                    report_headers = data_headers\n                    total_changed_counter[0] += stats['changed']\n\n                    # Summary block (rows 1-6)\n                    ws['A1'] = \"Report Summary\"\n                    ws['A1'].font      = fonts['bold']\n                    ws['A1'].alignment = center_align\n                    ws.merge_cells('A1:B1')\n                    for cell in ws['A1:A1'][0]: cell.fill = fills['summary']\n                    for cell in ws['B1:B1'][0]: cell.fill = fills['summary']\n\n                    summary_rows = {\n                        \"Total Rows:\":  stats['total'],\n                        \"Changed:\":     stats['changed'],\n                        \"No Change:\":   stats['no_change'],\n                        \"Errors:\":      stats['errors'],\n                    }\n                    for i, (key, value) in enumerate(summary_rows.items(), 2):\n                        ws.cell(row=i, column=1, value=key).font = fonts['bold']\n                        ws.cell(row=i, column=2, value=value).alignment = right_align\n                    timestamp_str = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n                    ws.merge_cells('A6:B6')\n                    ws['A6'].value     = \"Generated: {}\".format(timestamp_str)\n                    ws['A6'].font      = fonts['italic']\n                    ws['A6'].alignment = center_align\n                    for row in ws['A1:B6']:\n                        for cell in row: cell.fill = fills['summary']\n\n                    data_start = 8\n\n                    # Header row\n                    for i, value in enumerate(report_headers, 1):\n                        cell           = ws.cell(row=data_start, column=i, value=value)\n                        cell.font      = fonts['header']\n                        cell.fill      = fills['header']\n                        cell.alignment = center_align\n\n                    # Data rows — write values\n                    for i, row_info in enumerate(report_data):\n                        for j, value in enumerate(row_info['data'], 1):\n                            ws.cell(row=data_start + 1 + i, column=j,\n                                    value=safe_cell_value(value)).alignment = center_align\n\n                    # ── Highlighting rules (v1.9.2) ───────────────────────────\n                    # A row is only highlighted if something actually changed.\n                    # \"Changed\" = Update Status == \"Updated\" OR Moved == \"Moved\".\n                    # When a row HAS changes:\n                    #   - Connection ID column                    → yellow\n                    #   - Update Status column                    → yellow when == \"Updated\"\n                    #   - Moved column                            → yellow\n                    #   - Original/Updated Equipment ID           → yellow\n                    #   - Original/Updated Location (if moved)    → yellow via changed_cols\n                    #   - All other changed Original/Updated pairs → yellow via changed_cols\n                    # When a row has NO changes → everything white, no exceptions.\n                    CHANGED_FILL = PatternFill(start_color=\"FFFF00\", fill_type='solid')\n\n                    # ID anchor columns that get highlighted whenever the row has changes\n                    # Anchor col indices: Connection ID + Equip ID pair\n                    # (highlighted yellow whenever the row has ANY change)\n                    # 'Moved' is handled per-cell below (only yellow if == 'Moved')\n                    id_anchor_col_indices = {\n                        idx + 1\n                        for idx, h in enumerate(report_headers)\n                        if str(h).strip().lower() in (\n                            'connection id',\n                            'original: equipment id', 'updated: equipment id'\n                        )\n                    }\n\n                    # Find the 1-based column index for 'Update Status' / 'Moved'\n                    update_status_col_1based = next(\n                        (idx + 1 for idx, h in enumerate(report_headers)\n                         if str(h).strip().lower() == 'update status'),\n                        None\n                    )\n                    moved_col_1based = next(\n                        (idx + 1 for idx, h in enumerate(report_headers)\n                         if str(h).strip().lower() == 'moved'),\n                        None\n                    )\n\n                    if report_data:\n                        for i, row_obj in enumerate(ws.iter_rows(\n                                min_row=data_start + 1, max_row=ws.max_row,\n                                min_col=1, max_col=len(report_headers))):\n                            if i >= len(report_data): break\n                            row_info     = report_data[i]\n                            changed_cols = row_info.get('changed_cols', set())\n                            row_changed  = row_info.get('changed', False)\n                            row_data_vals = row_info.get('data', [])\n\n                            # Pre-compute: did this row actually update / move?\n                            update_status_col_0 = (\n                                update_status_col_1based - 1\n                                if update_status_col_1based else None\n                            )\n                            row_was_updated = (\n                                update_status_col_0 is not None and\n                                update_status_col_0 < len(row_data_vals) and\n                                str(row_data_vals[update_status_col_0]).strip() == 'Updated'\n                            )\n                            moved_col_0 = (moved_col_1based - 1) if moved_col_1based else None\n                            row_was_moved = (\n                                moved_col_0 is not None and\n                                moved_col_0 < len(row_data_vals) and\n                                str(row_data_vals[moved_col_0]).strip() == 'Moved'\n                            )\n\n                            for cell in row_obj:\n                                col_0 = cell.column - 1  # 0-based\n\n                                if row_changed and cell.column in id_anchor_col_indices:\n                                    # Connection ID + Equipment ID pair: yellow on any change\n                                    cell.fill = CHANGED_FILL\n                                elif update_status_col_1based and cell.column == update_status_col_1based:\n                                    # Update Status cell: yellow ONLY if this connector was actually updated\n                                    cell.fill = CHANGED_FILL if row_was_updated else fills['white']\n                                elif moved_col_1based and cell.column == moved_col_1based:\n                                    # Moved cell: yellow ONLY if this connector was actually moved\n                                    cell.fill = CHANGED_FILL if row_was_moved else fills['white']\n                                elif col_0 in changed_cols:\n                                    # This specific Original/Updated pair changed\n                                    cell.fill = CHANGED_FILL\n                                else:\n                                    # No change here — white\n                                    cell.fill = fills['white']\n\n                        # Freeze panes below summary + header\n                        ws.freeze_panes = ws.cell(row=data_start + 1, column=1)\n\n                        # Excel table\n                        range_str     = \"A{}:{}{}\".format(\n                            data_start,\n                            get_column_letter(len(report_headers)),\n                            data_start + len(report_data))\n                        safe_tbl_name = create_safe_table_name(validated_name)\n                        ctr = 1\n                        while safe_tbl_name in used_table_names:\n                            safe_tbl_name = \"{}{}\".format(\n                                create_safe_table_name(validated_name), ctr)\n                            ctr += 1\n                        used_table_names.add(safe_tbl_name)\n                        tbl = Table(displayName=safe_tbl_name, ref=range_str)\n                        tbl.tableStyleInfo = TableStyleInfo(\n                            name=BASE_TABLE_STYLE,\n                            showFirstColumn=False, showLastColumn=False,\n                            showRowStripes=False,  showColumnStripes=False)\n                        ws.add_table(tbl)\n\n                # ── Column auto-sizing ────────────────────────────────────────\n                col_widths = {}\n                for row in ws.rows:\n                    for cell in row:\n                        if cell.value:\n                            adjusted = (len(str(cell.value)) * 1.15) + 1\n                            col_widths[cell.column] = max(col_widths.get(cell.column, 0), adjusted)\n                for col_idx, max_len in col_widths.items():\n                    ws.column_dimensions[get_column_letter(col_idx)].width = min(max_len, MAX_COLUMN_WIDTH)\n\n                logger.log(\"Sheet '{}' created successfully.\".format(validated_name))\n                return True\n\n            except Exception as e:\n                logger.error(\"Failed to process sheet '{}': {}\\n{}\".format(\n                    validated_name or 'Unknown', e, traceback.format_exc()))\n                return False\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 8 — WORKBOOK ORCHESTRATOR\n# ═══════════════════════════════════════════════════════════════════════════════\n\n        def create_multi_sheet_excel_report(filepath, sheet_configs, logger,\n                                            theme_config, total_changed_counter):\n            is_path_valid, validated_filepath, is_default_path = validate_filepath(filepath, logger)\n            if not is_path_valid:\n                return False, \"Filepath validation failed.\"\n            try:\n                wb = openpyxl.Workbook()\n                wb.remove(wb.active)\n                used_sheet_names = set()\n                used_table_names = set()\n                sheet_count      = 0\n\n                for config in sheet_configs:\n                    orig_name  = config.get('name', 'Report Sheet')\n                    valid_name = validate_sheet_name(orig_name, logger)\n                    final_name = valid_name\n                    ctr        = 1\n                    while final_name in used_sheet_names:\n                        suffix     = \"_{}\".format(ctr)\n                        final_name = valid_name[:MAX_SHEET_NAME_LENGTH - len(suffix)] + suffix\n                        ctr       += 1\n                    if final_name != orig_name:\n                        logger.warning(\"Sheet '{}' renamed to '{}'.\".format(orig_name, final_name))\n                    config['name'] = final_name\n                    used_sheet_names.add(final_name)\n\n                    if process_and_create_sheet(wb, config, logger, used_table_names,\n                                               theme_config, total_changed_counter):\n                        sheet_count += 1\n\n                if sheet_count == 0:\n                    logger.warning(\"No data sheets were created.\")\n\n                # ── Script Log sheet ──────────────────────────────────────────\n                log_ws = wb.create_sheet(title=\"Script Log\")\n                log_ws.append([\"Timestamp\", \"Elapsed (s)\", \"Level\", \"Message\"])\n                pattern   = re.compile(r\"\\[(.*?)\\]\\[(.*?)s\\]\\[(.*?)\\] (.*)\", re.DOTALL)\n                hdr_fill  = PatternFill(start_color=theme_config['log_header_color'], fill_type='solid')\n                stripe_f  = PatternFill(start_color='FFEAEAEA', fill_type='solid')\n                error_f   = PatternFill(start_color='FFFFC7CE', fill_type='solid')\n                warn_f    = PatternFill(start_color='FFFFEB9C', fill_type='solid')\n                hdr_font  = Font(bold=True, color=\"FFFFFF\")\n                center_a  = Alignment(horizontal='center', vertical='center')\n                wrap_a    = Alignment(horizontal='left', vertical='top', indent=1, wrap_text=True)\n\n                for msg in logger.get_messages():\n                    m = pattern.match(msg)\n                    if m: log_ws.append([m.group(1), float(m.group(2)), m.group(3), m.group(4)])\n                    else:  log_ws.append([\"\", \"\", \"\", msg])\n\n                for cell in log_ws[\"1:1\"]:\n                    cell.font, cell.fill, cell.alignment = hdr_font, hdr_fill, center_a\n                for row_num in range(2, log_ws.max_row + 1):\n                    fill = stripe_f if row_num % 2 == 0 else None\n                    level = log_ws.cell(row=row_num, column=3).value\n                    if level == \"ERROR\": fill = error_f\n                    elif level == \"WARN\": fill = warn_f\n                    for col_num in range(1, 5):\n                        c = log_ws.cell(row=row_num, column=col_num)\n                        c.alignment = wrap_a if col_num == 4 else center_a\n                        if fill: c.fill = fill\n\n                for col, width in [('A', 12), ('B', 12), ('C', 10), ('D', 100)]:\n                    log_ws.column_dimensions[col].width = width\n                log_ws.freeze_panes = 'A2'\n\n                # ── Save ──────────────────────────────────────────────────────\n                final_fp = validated_filepath\n                logger.log(\"Saving workbook to: {}\".format(final_fp))\n                try:\n                    wb.save(filename=final_fp)\n                except PermissionError:\n                    logger.warning(\"Save failed — file is open. Saving with timestamp suffix.\")\n                    p        = Path(validated_filepath)\n                    final_fp = p.with_name(\"{}_{}{}\".format(\n                        p.stem, datetime.now().strftime('%Y%m%d_%H%M%S'), p.suffix))\n                    wb.save(filename=final_fp)\n\n                if platform.system() == \"Windows\":\n                    os.startfile(final_fp)\n\n                return True, \"Excel report with {} sheet(s) created: {}\".format(\n                    sheet_count, os.path.basename(final_fp))\n\n            except Exception as e:\n                msg = \"Unexpected error: {}\\n{}\".format(e, traceback.format_exc())\n                logger.error(msg)\n                return False, msg\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 9 — MAIN ENTRY POINT\n#\n#   Parses inputs, classifies each data package (Simple vs Comparison),\n#   auto-generates an \"All Updates Only\" companion sheet for any Comparison\n#   sheet (filtering to rows where Update Status = \"Updated\"), then\n#   calls the workbook orchestrator.\n# ═══════════════════════════════════════════════════════════════════════════════\n\n        def main():\n            try:\n                if len(IN) < 3:\n                    raise ValueError(\"Insufficient inputs. Expected filepath, sheet_names, theme.\")\n\n                filepath, sheet_names, theme_input = IN[0], IN[1], IN[2]\n                data_packages = IN[3:]\n                theme_config  = get_theme_config(theme_input, logger)\n                sheet_names   = [sheet_names] if isinstance(sheet_names, str) else sheet_names\n\n                if not isinstance(sheet_names, list):\n                    raise TypeError(\"Sheet names (IN[1]) must be a list.\")\n\n                n_names    = len(sheet_names)\n                n_packages = len(data_packages)\n                n_process  = min(n_names, n_packages)\n                if n_names != n_packages:\n                    logger.warning(\"Name/package count mismatch ({} vs {}). \"\n                                   \"Processing {}.\".format(n_names, n_packages, n_process))\n\n                total_changed_counter = [0]\n                sheet_configs         = []\n\n                # ── Build sheet configs ───────────────────────────────────────\n                for i in range(n_process):\n                    sheet_name = sheet_names[i]\n                    package    = data_packages[i]\n                    headers, data_columns, error = normalize_data_package(package, logger)\n\n                    if error:\n                        logger.error(\"Invalid data for sheet '{}': {}\".format(sheet_name, error))\n                        sheet_configs.append({\n                            'name': sheet_name,\n                            'type': 'Error',\n                            'error_message': (\"The data package for this sheet was null or \"\n                                              \"in an unrecognized format. See Script Log.\")\n                        })\n                        continue\n\n                    config       = {'name': sheet_name, 'headers': headers, 'columns': data_columns}\n                    header_str   = ' '.join(str(h) for h in headers).lower()\n                    is_sow_log   = isinstance(package, dict) and 'debug_log' in package\n\n                    if is_sow_log:\n                        config['type']           = 'Simple'\n                        summary_data             = {k: (v[0] if isinstance(v, list) and len(v) == 1 else v)\n                                                    for k, v in package.items() if k != 'debug_log'}\n                        config['summary_header'] = summary_data\n                        config['headers']        = ['Log Messages']\n                        config['columns']        = [package.get('debug_log', [])]\n                    elif 'original' in header_str and 'updated' in header_str:\n                        logger.log(\"Classifying '{}' as Comparison report.\".format(sheet_name))\n                        config['type']           = 'Comparison'\n                        config['summary_header'] = None\n                    else:\n                        logger.log(\"Classifying '{}' as Simple report.\".format(sheet_name))\n                        config['type']           = 'Simple'\n                        config['summary_header'] = None\n\n                    sheet_configs.append(config)\n\n                # ── Auto-add \"All Updates Only\" for Comparison sheets ─────────\n                # Includes rows where Update Status == \"Updated\" (param changes)\n                # OR Moved == \"Moved\" (position changed), so nothing is missed.\n                auto_sheets = []\n                for i in range(n_process):\n                    cfg = sheet_configs[i] if i < len(sheet_configs) else None\n                    if not cfg or cfg.get('type') != 'Comparison':\n                        continue\n                    raw_pkg = data_packages[i]\n                    if not (isinstance(raw_pkg, list) and len(raw_pkg) > 1 and\n                            isinstance(raw_pkg[0], list)):\n                        continue\n\n                    hdr        = raw_pkg[0]\n                    status_idx = next(\n                        (j for j, h in enumerate(hdr) if str(h).strip().lower() == 'update status'),\n                        None\n                    )\n                    moved_idx  = next(\n                        (j for j, h in enumerate(hdr) if str(h).strip().lower() == 'moved'),\n                        None\n                    )\n                    if status_idx is None and moved_idx is None:\n                        continue\n\n                    def row_has_any_change(r):\n                        was_updated = (status_idx is not None and\n                                       len(r) > status_idx and\n                                       str(r[status_idx]).strip() == 'Updated')\n                        was_moved   = (moved_idx is not None and\n                                       len(r) > moved_idx and\n                                       str(r[moved_idx]).strip() == 'Moved')\n                        return was_updated or was_moved\n\n                    filtered = [hdr] + [r for r in raw_pkg[1:] if row_has_any_change(r)]\n                    if len(filtered) <= 1:\n                        logger.log(\"No updated rows found for 'All Updates Only' sheet.\")\n                        continue\n\n                    fh, fc, ferr = normalize_data_package(filtered, logger)\n                    if ferr:\n                        continue\n\n                    auto_sheets.append({\n                        'name':           'All Updates Only',\n                        'type':           'Comparison',\n                        'headers':        fh,\n                        'columns':        fc,\n                        'summary_header': None,\n                    })\n                    logger.log(\"Auto-added 'All Updates Only' with {} updated row(s).\".format(\n                        len(filtered) - 1))\n\n                sheet_configs.extend(auto_sheets)\n\n                if not sheet_configs:\n                    logger.warning(\"No sheet configurations assembled.\")\n\n                success, message = create_multi_sheet_excel_report(\n                    filepath, sheet_configs, logger, theme_config, total_changed_counter)\n\n                logger.log(\"Script {}.\".format(\"completed successfully\" if success else \"completed with errors\"))\n                return [message, logger.get_messages(), str(total_changed_counter[0])]\n\n            except Exception as e:\n                err = \"Fatal error in main(): {}\\n{}\".format(e, traceback.format_exc())\n                logger.error(err)\n                return [err, logger.get_messages(), \"0\"]\n\n        OUT = main()\n",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "5aac8cc4394f44a2bbcd8f45c39c998c",
