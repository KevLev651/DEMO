  "Nodes": [
    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "NodeType": "CodeBlockNode",
      "Code": "// ═══════════════════════════════════════════════════════════════════════════════\n// GRAPH 2 — EXTRACTOR CONFIGURATION\n//\n// Feeds the Excel Data Extractor node with:\n//   OUT[0] Sheet name           → Extractor.IN[1]\n//   OUT[1] Excel→Revit mapping  → Extractor.IN[2]\n//            Full set matching the UM-Revit Mapping sheet.\n//            \"Frequency\" and \"Short Circuit Rating\" excluded — not in Main sheet.\n//   OUT[2] Header row index (4) → Extractor.IN[3]\n//   OUT[3] Primary filter       → Extractor.IN[4]\n//            Filters rows to known service abbreviations only.\n//   OUT[4] Supplementary filter → Extractor.IN[5]\n//            Excludes rows marked Obsolete.\n// ═══════════════════════════════════════════════════════════════════════════════\n\n\"Main\";\n // OUT[0] → Extractor.IN[1];\n\n// OUT[1] → Extractor.IN[2]\n// All columns present in the Main sheet that have a UM-Revit Mapping entry.\n// The second element of each pair is the Revit parameter name — used only as\n// a fallback label. The writer resolves all param names from the UM-Revit\n// Mapping sheet at runtime, so this list drives WHAT to pull from Excel.\n[\n    [\"Equipment ID\",                       \"Equipment ID\"],\n    [\"Equipment Description\",              \"Equipment Description\"],\n    [\"Connection ID\",                      \"Connection ID\"],\n    [\"Equipment Condition\",                \"Condition\"],\n    [\"Equipment Type\",                     \"Equipment Type\"],\n    [\"Functional Area\",                    \"Functional Area\"],\n    [\"Line Number\",                        \"Line Designator\"],\n    [\"Manufacturer\",                       \"OEM\"],\n    [\"Model Number\",                       \"Model Number\"],\n    [\"Vendor Drawing\",                     \"OEM Drawing\"],\n    [\"Power Source (Control Panel)\",       \"Power Source Control Panel\"],\n    [\"Connection Type\",                    \"Connection Type\"],\n    [\"Connection Size\",                    \"Nominal Diameter,Connection Size\"],\n    [\"Service Abbreviation\",               \"Service\"],\n    [\"Service Category\",                   \"System Type\"],\n    [\"OEM Device ID\",                      \"OEM Device ID\"],\n    [\"OEM Device Description\",             \"OEM Device Description\"],\n    [\"Installation Notes\",                 \"Installation Notes\"],\n    [\"Utility Status\",                     \"Utility Status\"],\n    [\"Mech - Diversity\",                   \"Mechanical Demand Factor\"],\n    [\"Mech - Fed From\",                    \"Fed From\"],\n    [\"Flow\",                               \"Flow-Unitless\"],\n    [\"Flow Unit\",                          \"Flow Unit\"],\n    [\"Temp (F°)\",                          \"Operating Temperature\"],\n    [\"Pressure\",                           \"Pressure-Unitless\"],\n    [\"Pressure Unit\",                      \"Pressure Unit\"],\n    [\"Isolation Valve Supplied By\",        \"Isolation Valve\"],\n    [\"Filter Regulator Supplied By\",       \"Filter Regulator\"],\n    [\"Air Handling- Intake Source Room\",   \"Source\"],\n    [\"Air Handling - Operation Mode\",      \"Air Operation Mode\"],\n    [\"Air Handling - Termination\",         \"Termination\"],\n    [\"Apparent Load (FLA)\",                \"Full Load Current\"],\n    [\"Elec - Diversity\",                   \"Elec Demand Factor\"],\n    [\"Horsepower\",                         \"Design Total Power\"],\n    [\"LMD Supplied By\",                    \"Local Motor Disconnect\"],\n    [\"Maximum Overcurrent Protection (A)\", \"Maximum Overcurrent Protection\"],\n    [\"Tele - IP Address\",                  \"Network Address\"],\n    [\"Tele - Subnet\",                      \"Subnet\"],\n    [\"Voltage & Phase\",                    \"Family Type,Neutral Required\"],\n    [\"Weight - Non-Operating (lbs)\",       \"Weight\"],\n    [\"Weight - Operating (lbs)\",           \"Operating Weight\"]\n];\n // OUT[1] → Extractor.IN[2];\n\n4;\n // OUT[2] → Extractor.IN[3]  (header row is row 4 in the Main sheet);\n\n// OUT[3] → Extractor.IN[4]  Primary filter: service abbreviation whitelist\n[\"Connection ID\",\n    [\n        \"CA\", \"DRN\", \"EL\", \"EX\", \"HH\",\n        \"INT\", \"PCW\", \"PHW\", \"TD\"\n    ]\n];\n // OUT[3];\n\n// OUT[4] → Extractor.IN[5]  Supplementary filter: exclude obsolete rows\n{\n    \"logic\": \"AND\",\n    \"filters\": [[\"Obsolete\", [\"\"]]]\n};\n // OUT[4];",
      "Id": "e94bc789325d4274bff4224c29ea9288",
      "Inputs": [],
