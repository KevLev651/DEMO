      {
        "Id": "c0f4fcd6c90d42b98a93fb44e5f9a101",
        "Title": "Finds & Places Connectors & Parameters",
        "DescriptionText": "Description:\nReads the Utility Matrix Excel file to determine what process connectors are needed for each piece of equipment. For each equipment item (Data Cube) in the model, it checks what connectors already exist and what's missing, then inserts any missing connector families at the correct location. Existing connectors can optionally be repositioned to align with their parent equipment. After placement, all connector parameters (service, functional area, line number, etc.) are automatically populated from the Utility Matrix using the UM-Revit Mapping sheet to ensure the right data goes to the right connector type. Any connectors found in the model that don't match the Matrix are flagged as rogues in the output report.",
        "IsExpanded": true,
        "WidthAdjustment": 0.0,
        "HeightAdjustment": 0.0,
        "Nodes": [
          "22de31005e2849bbb3e2bab53712def9",
          "773ef90fef2146ffb7939aa2bdde852e"
        ],
        "HasNestedGroups": false,
        "Left": -923.9838947123626,
        "Top": -1162.0065360890903,
        "Width": 991.9200927644772,
        "Height": 798.29781838953727,
