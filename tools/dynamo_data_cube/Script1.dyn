    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# ExcelGen\r\n#\r\n# Excel Report Generator\r\n# \r\n# Revit 2023 / Dynamo 2.16 / CPython3\r\n# Developed By - Chris Staker\r\n# Developed On - 06/13/2025\r\n# v1.0.0 - Initial Release\r\n# v1.1.0 - Added Table Color / Theme Input (07/09/2025)\r\n# v1.2.0 - Added support for multiple input formats (07/15/2025)\r\n#        - Simple List of values\r\n#        - Single Dictionary\r\n#        - List of Dictionaries (Rows) or a Dictionary of Lists (Columns)\r\n#        - Implemented logic for Simple/Log and Comparison reports\r\n# v1.3.0 - Added support for List of Lists (table) format (07/17/25)\r\n# v1.4.0 - Added updated counter output (08/10/2025)\r\n# v1.5.0 - Updated highlight logic (08/15/2025)\r\n#        - Fixed bug causing duplicate Excel files with default path\r\n#        - Enhanced column auto-sizing logic\r\n#        - Added configuration, data shape validation, and comments\r\n# v1.6.0 - Ensured Excel report is always created, adding placeholder\r\n#          sheets for invalid data packages (08/15/2025)\r\n# v1.7.0 - Replaced desktop folder logic with local 'C' drive path\r\n#          for Python Support Package location (08/22/2025)\r\n# v1.7.1 - Fixed row striping for Simple reports. (09/10/2025)\r\n# v1.7.2 - Added center alignment for single values or short text\r\n#          (≤35 chars) in Simple report data cells (09/12/2025)\r\n\r\n# --- SCRIPT CONFIGURATION ---\r\n# Central location for settings that might need to be changed.\r\nDEPENDENCY_FOLDER_NAME = \"Python Support Pckg\"\r\nLOCAL_LIBRARY_PATH = r\"C:\\Dynamo\\2.16\\Python Support Pckg\"\r\nNETWORK_LIBRARY_PATH = r\"K:\\CAD\\_Revit2023\\Add_Ins\\Python Support Pckg\"\r\n\r\n# --- Standard Library Imports ---\r\nimport sys\r\nimport os\r\nimport platform\r\nimport time\r\nfrom datetime import datetime\r\nfrom pathlib import Path\r\nimport re\r\nimport traceback\r\nimport colorsys\r\n\r\n# --- Helper Classes ---\r\nclass Logger:\r\n    \"\"\"A simple class to handle logging with timestamps and execution time.\"\"\"\r\n    def __init__(self):\r\n        \"\"\"Initializes the logger and records the start time.\"\"\"\r\n        self.messages = []\r\n        self.start_time = time.time()\r\n\r\n    def log(self, message, level=\"INFO\"):\r\n        \"\"\"Records a log message with a timestamp, elapsed time, and level.\"\"\"\r\n        timestamp = datetime.now().strftime(\"%H:%M:%S\")\r\n        elapsed = round(time.time() - self.start_time, 2)\r\n        try:\r\n            # Safely encode and decode the message to handle potential special characters.\r\n            msg_str = str(message).encode('utf-8', 'replace').decode('utf-8')\r\n            formatted_msg = \"[{}][{}s][{}] {}\".format(timestamp, elapsed, level, msg_str)\r\n            self.messages.append(formatted_msg)\r\n        except Exception:\r\n            self.messages.append(\"[{}][{}s][ERROR] Error formatting log message.\".format(timestamp, elapsed))\r\n    \r\n    def error(self, message): self.log(message, \"ERROR\")\r\n    def warning(self, message): self.log(message, \"WARN\")\r\n    def get_messages(self): return self.messages\r\n\r\n# --- DEPENDENCY PATH HANDLING (WITH LOGGING) ---\r\ndef setup_library_paths(logger):\r\n    \"\"\"\r\n    Checks for the required dependency folder in standard locations (Local C Drive, Network) and adds it to the system path if found.\r\n    Uses constants defined in the SCRIPT CONFIGURATION section.\r\n    Returns:\r\n        tuple: (found_status, found_path, location_name)\r\n    \"\"\"\r\n    logger.log(\"--- Running Dependency Check ---\")\r\n    \r\n    # First, check the local C drive location.\r\n    logger.log(\"Checking local C drive for libraries...\")\r\n    if os.path.isdir(LOCAL_LIBRARY_PATH):\r\n        logger.log(f\"✓ Found library path on Local C Drive: {LOCAL_LIBRARY_PATH}\")\r\n        if LOCAL_LIBRARY_PATH not in sys.path: sys.path.insert(0, LOCAL_LIBRARY_PATH)\r\n        return True, LOCAL_LIBRARY_PATH, \"Local C Drive\"\r\n\r\n    # If not found on local C drive, check the predefined network drive location.\r\n    logger.log(\"Local C drive path not found. Checking network drive...\")\r\n    if os.path.isdir(NETWORK_LIBRARY_PATH):\r\n        logger.log(f\"✓ Found library path on Network Drive: {NETWORK_LIBRARY_PATH}\")\r\n        if NETWORK_LIBRARY_PATH not in sys.path: sys.path.insert(0, NETWORK_LIBRARY_PATH)\r\n        return True, NETWORK_LIBRARY_PATH, \"Network Drive\"\r\n    \r\n    # If the library is not found in any location, log an error.\r\n    logger.error(\"[X] FAILURE: Could not find the required library folder in any predefined location.\")\r\n    return False, None, None\r\n\r\n# --- SCRIPT EXECUTION CONTROL FLOW ---\r\nlogger = Logger()\r\nlogger.log(\"Multi-Sheet Excel Report Script Started\")\r\npath_found, found_path, location_name = setup_library_paths(logger)\r\n\r\n# Main guard clause: exit if the required 'openpyxl' library cannot be imported.\r\nif not path_found:\r\n    error_message = (\"FATAL ERROR: Could not find the required 'openpyxl' library.\")\r\n    OUT = [error_message, logger.get_messages(), \"0\"]\r\nelse:\r\n    try:\r\n        # Attempt to import the library now that the path has been added.\r\n        import openpyxl\r\n        from openpyxl.styles import PatternFill, Font, Alignment\r\n        from openpyxl.utils import get_column_letter\r\n        from openpyxl.worksheet.table import Table, TableStyleInfo\r\n        logger.log(f\"✓ Successfully imported 'openpyxl' from {location_name}.\")\r\n    except ImportError as e:\r\n        error_message = (f\"FATAL ERROR: Import failed from '{found_path}'. Details: {e}\")\r\n        logger.error(error_message)\r\n        OUT = [error_message, logger.get_messages(), \"0\"]\r\n\r\n    else:\r\n        # --- CONSTANTS ---\r\n        # Defines static values used throughout the Excel creation process.\r\n        MAX_SHEET_NAME_LENGTH, MAX_COLUMN_WIDTH = 31, 120\r\n        CHANGED_HIGHLIGHT_COLOR_A = \"FFFFFF99\" # Soft Yellow 1\r\n        CHANGED_HIGHLIGHT_COLOR_B = \"FFFFFFCC\" # Soft Yellow 2\r\n        BASE_TABLE_STYLE = \"TableStyleMedium2\" # A neutral black/white/gray style\r\n\r\n        # --- THEME AND COLOR LOGIC ---\r\n        def create_theme_shades(hex_color):\r\n            \"\"\"Generates lighter shades for a given hex color for UI theming.\"\"\"\r\n            try:\r\n                hex_color = hex_color.lstrip('#')\r\n                r, g, b = (int(hex_color[i:i+2], 16) / 255.0 for i in (0, 2, 4))\r\n                h, l, s = colorsys.rgb_to_hls(r, g, b)\r\n                summary_l = l + (1 - l) * 0.7 \r\n                summary_r, summary_g, summary_b = [int(c * 255) for c in colorsys.hls_to_rgb(h, summary_l, s)]\r\n                stripe_l = l + (1 - l) * 0.9\r\n                stripe_s = s * 0.5\r\n                stripe_r, stripe_g, stripe_b = [int(c * 255) for c in colorsys.hls_to_rgb(h, stripe_l, stripe_s)]\r\n                return { \"summary\": f\"FF{summary_r:02X}{summary_g:02X}{summary_b:02X}\", \"stripe\": f\"FF{stripe_r:02X}{stripe_g:02X}{stripe_b:02X}\" }\r\n            except Exception:\r\n                return {\"summary\": \"FFF0F0F0\", \"stripe\": \"FFF9F9F9\"}\r\n\r\n        def get_theme_config(theme_input, logger):\r\n            \"\"\"\r\n            Resolves a user-provided theme name or hex code into a full color configuration dictionary.\r\n            \"\"\"\r\n            THEMES = { \"blue\": \"4472C4\", \"green\": \"70AD47\", \"red\": \"C5504B\", \"purple\": \"7030A0\", \"orange\": \"ED7D31\", \"teal\": \"264653\" }\r\n            theme_input = str(theme_input).lower().strip() if theme_input else \"blue\"\r\n            hex_color = THEMES.get(theme_input)\r\n            \r\n            if not hex_color:\r\n                hex_color = theme_input.lstrip('#')\r\n                if not (len(hex_color) == 6 and all(c in '0123456789abcdef' for c in hex_color)):\r\n                    logger.warning(f\"Invalid theme or color '{str(theme_input)}'. Using default 'blue' theme.\")\r\n                    hex_color = THEMES[\"blue\"]\r\n                else: \r\n                    logger.log(f\"Using custom hex color: #{hex_color.upper()}\")\r\n            else: \r\n                logger.log(f\"Using predefined theme: '{theme_input.capitalize()}'\")\r\n            \r\n            shades = create_theme_shades(hex_color)\r\n            return { \"header_color\": f\"FF{hex_color.upper()}\", \"summary_background\": shades[\"summary\"], \"stripe_background\": shades[\"stripe\"], \"log_header_color\": f\"FF{hex_color.upper()}\" }\r\n        \r\n        # --- HELPER FUNCTIONS ---\r\n        def safe_cell_value(value):\r\n            \"\"\"Sanitizes a value to be safely written to an Excel cell.\"\"\"\r\n            if value is None: return \"\"\r\n            try: str_value = str(value)\r\n            except: str_value = repr(value)\r\n            str_value = re.sub(r'[\\x00-\\x08\\x0B\\x0C\\x0E-\\x1F\\x7F]', '', str_value)\r\n            return str_value[:32767]\r\n        \r\n        def create_safe_table_name(sheet_name):\r\n            \"\"\"Creates a valid Excel table name from a sheet name.\"\"\"\r\n            safe_name = re.sub(r'[^\\w]', '', sheet_name)\r\n            if not safe_name or not safe_name[0].isalpha(): safe_name = \"Table\" + safe_name\r\n            return safe_name[:250] + \"Data\"\r\n\r\n        def should_center_align_data(value):\r\n            \"\"\"\r\n            Determines if a data value should be center-aligned based on content.\r\n            Returns True for single values or text with ≤30 characters.\r\n            \"\"\"\r\n            if value is None or value == \"\":\r\n                return True\r\n            \r\n            str_value = str(value).strip()\r\n            return len(str_value) <= 35\r\n\r\n        def validate_filepath(filepath, logger):\r\n            \"\"\"\r\n            Validates a user-provided filepath. If invalid, generates a default path on the Desktop.\r\n            Returns:\r\n                tuple: (is_valid, final_filepath, was_path_generated_by_script)\r\n            \"\"\"\r\n            logger.log(f\"Received filepath input: '{filepath}'\")\r\n            is_valid, is_default_path = False, False\r\n            if filepath and isinstance(filepath, str) and filepath.strip():\r\n                filepath = filepath.strip()\r\n                dir_name = os.path.dirname(filepath)\r\n                if dir_name and os.path.isdir(dir_name):\r\n                    is_valid = True; logger.log(f\"✓ Directory exists, using provided filepath: '{filepath}'\")\r\n                elif not dir_name:\r\n                    logger.log(\"Filename only provided, creating default save location...\")\r\n                else: \r\n                    logger.warning(f\"The directory in the provided filepath does not exist: '{dir_name}'\")\r\n            else: \r\n                logger.warning(\"Filepath is empty, None, or invalid type.\")\r\n            \r\n            if not is_valid:\r\n                is_default_path = True\r\n                logger.log(\"Creating default save location on user's Desktop...\")\r\n                try:\r\n                    home_dir = os.path.expanduser(\"~\")\r\n                    desktop_path = os.path.join(home_dir, \"Desktop\")\r\n                    for item in os.listdir(home_dir):\r\n                        if \"onedrive\" in item.lower():\r\n                            onedrive_desktop = os.path.join(home_dir, item, \"Desktop\")\r\n                            if os.path.isdir(onedrive_desktop):\r\n                                desktop_path = onedrive_desktop; break\r\n                    base_name = os.path.basename(filepath.strip()) if filepath and isinstance(filepath, str) and filepath.strip() else \"\"\r\n                    if not base_name:\r\n                        logger.log(\"Creating a default filename with timestamp.\")\r\n                        base_name = f\"Multi_Sheet_Report_{datetime.now().strftime('%Y%m%d_%H%M%S')}.xlsx\"\r\n                    else: \r\n                        logger.log(f\"Preserving original filename: '{base_name}'\")\r\n                    if not base_name.lower().endswith('.xlsx'): base_name = os.path.splitext(base_name)[0] + \".xlsx\"\r\n                    filepath = os.path.join(desktop_path, base_name)\r\n                    logger.log(f\"Generated new valid filepath on Desktop: {filepath}\")\r\n                except Exception as e:\r\n                    logger.error(f\"Could not create a default path on the Desktop. Error: {e}\"); return False, None, False\r\n            \r\n            if not filepath.lower().endswith('.xlsx'): filepath += '.xlsx'\r\n            logger.log(f\"Final validated filepath: {filepath}\")\r\n            return True, filepath, is_default_path\r\n\r\n        def validate_sheet_name(sheet_name, logger):\r\n            \"\"\"Sanitizes a string to be a valid Excel sheet name.\"\"\"\r\n            if not sheet_name: logger.warning(\"Sheet name is empty, using default\"); return \"Report Sheet\"\r\n            sheet_name = str(sheet_name)\r\n            sheet_name = re.sub(r'[\\\\/?*\\[\\]:]', '_', sheet_name)\r\n            sheet_name = sheet_name.strip(\"'\\\"\")\r\n            if len(sheet_name) > MAX_SHEET_NAME_LENGTH:\r\n                sheet_name = sheet_name[:MAX_SHEET_NAME_LENGTH]\r\n                logger.warning(f\"Sheet name truncated to {MAX_SHEET_NAME_LENGTH} characters.\")\r\n            return sheet_name\r\n\r\n        def normalize_data_package(package, logger):\r\n            \"\"\"\r\n            Inspects the input data package and converts it into a standardized format.\r\n            Standard Format: (headers_list, list_of_data_columns, error_message)\r\n            Handles multiple common data structures from Dynamo.\r\n            \"\"\"\r\n            if (isinstance(package, list) and len(package) > 0 and\r\n                all(isinstance(row, list) for row in package)):\r\n                logger.log(\"Detected list of lists (table) format.\")\r\n                headers = package[0]\r\n                data_rows = package[1:]\r\n                num_headers = len(headers)\r\n                \r\n                sanitized_rows = []\r\n                for i, row in enumerate(data_rows):\r\n                    num_items = len(row)\r\n                    if num_items != num_headers:\r\n                        logger.warning(f\"Row {i+1} has {num_items} items, but header has {num_headers}. Row will be adjusted.\")\r\n                        if num_items < num_headers:\r\n                            sanitized_rows.append(row + [''] * (num_headers - num_items))\r\n                        else:\r\n                            sanitized_rows.append(row[:num_headers])\r\n                    else:\r\n                        sanitized_rows.append(row)\r\n                \r\n                if not sanitized_rows: \r\n                    return headers, [[] for _ in headers], None\r\n                data_columns = list(map(list, zip(*sanitized_rows)))\r\n                return headers, data_columns, None\r\n            \r\n            if isinstance(package, list) and len(package) == 2 and isinstance(package[0], list) and isinstance(package[1], dict):\r\n                logger.log(\"Detected legacy data format: [headers_list, data_dict].\")\r\n                headers = package[0]\r\n                data_dict = package[1]\r\n                data_columns = [data_dict.get(h, []) for h in headers]\r\n                return headers, data_columns, None\r\n\r\n            if isinstance(package, dict):\r\n                logger.log(\"Detected column-oriented dictionary format.\")\r\n                if not package: return [], [], None\r\n                headers = list(package.keys())\r\n                data_columns = [v if isinstance(v, list) else [v] for v in package.values()]\r\n                return headers, data_columns, None\r\n\r\n            if isinstance(package, list) and (not package or all(isinstance(i, dict) for i in package)):\r\n                logger.log(\"Detected row-oriented list of dictionaries format.\")\r\n                if not package: return [], [], None\r\n                ordered_headers = []\r\n                header_set = set()\r\n                for row in package:\r\n                    for key in row.keys():\r\n                        if key not in header_set:\r\n                            header_set.add(key); ordered_headers.append(key)\r\n                data_columns = [[row.get(header) for row in package] for header in ordered_headers]\r\n                return ordered_headers, data_columns, None\r\n            \r\n            if isinstance(package, list):\r\n                logger.log(\"Detected simple list format.\"); return [\"Value\"], [package], None\r\n\r\n            err_msg = \"Data package has an unrecognized format or is null.\"\r\n            logger.error(err_msg)\r\n            return None, None, err_msg\r\n            \r\n        def process_element_data(data_inputs, headers, logger):\r\n            \"\"\"\r\n            Processes columnar data for a 'Comparison' report.\r\n            Identifies 'original' and 'updated' columns, compares their values row-by-row, and calculates statistics.\r\n            \"\"\"\r\n            report_data, stats = [], {\"total\": 0, \"changed\": 0, \"no_change\": 0, \"errors\": 0}\r\n            if not data_inputs or not any(data_inputs): return report_data, stats\r\n            \r\n            comparison_pairs, original_cols, updated_cols = [], {}, {}\r\n            for idx, header in enumerate(headers):\r\n                h_lower = str(header).lower()\r\n                if 'original' in h_lower: original_cols[h_lower.replace('original', '').strip()] = idx\r\n                if 'updated' in h_lower: updated_cols[h_lower.replace('updated', '').strip()] = idx\r\n            for key, orig_idx in original_cols.items():\r\n                if key in updated_cols: comparison_pairs.append((orig_idx, updated_cols[key]))\r\n            \r\n            num_rows = len(data_inputs[0]) if data_inputs and data_inputs[0] else 0\r\n            for i in range(num_rows):\r\n                stats[\"total\"] += 1\r\n                try:\r\n                    row_data = [(data_list[i] if i < len(data_list) else \"\") for data_list in data_inputs]\r\n                    has_changed = any(str(row_data[orig_idx]).strip() != str(row_data[upd_idx]).strip() for orig_idx, upd_idx in comparison_pairs)\r\n                    row_data.append(\"Changed\" if has_changed else \"No Change\")\r\n                    if has_changed: stats[\"changed\"] += 1\r\n                    else: stats[\"no_change\"] += 1\r\n                    report_data.append({'data': row_data, 'changed': has_changed})\r\n                except Exception as e:\r\n                    stats[\"errors\"] += 1; logger.error(f\"Error processing data at index {i}: {e}\")\r\n            logger.log(f\"Data processing completed. Stats: {stats}\"); return report_data, stats\r\n\r\n        def process_and_create_sheet(wb, sheet_config, logger, used_table_names, theme_config, total_changed_counter):\r\n            \"\"\"\r\n            Creates and formats a single worksheet based on a configuration dictionary.\r\n            Handles 'Simple', 'Comparison', and 'Error' report types.\r\n            \"\"\"\r\n            validated_sheet_name = \"\"\r\n            try:\r\n                config_name = sheet_config.get('name', 'Report Sheet')\r\n                report_type = sheet_config.get('type')\r\n\r\n                validated_sheet_name = validate_sheet_name(config_name, logger)\r\n                logger.log(f\"--- Processing Sheet: '{validated_sheet_name}' (Type: {report_type or 'Unknown'}) ---\")\r\n                ws = wb.create_sheet(title=validated_sheet_name)\r\n                \r\n                # --- Logic for 'Error' Report Type ---\r\n                if report_type == 'Error':\r\n                    error_message = sheet_config.get('error_message', 'An unspecified error occurred.')\r\n                    ws['A1'] = \"Data Error\"\r\n                    ws['A1'].font = Font(bold=True, size=16, color=\"C00000\") # Red, bold font\r\n                    ws['A2'] = error_message\r\n                    ws.column_dimensions['A'].width = 100\r\n                    ws['A2'].alignment = Alignment(wrap_text=True, vertical='top')\r\n                    logger.log(f\"Created placeholder error sheet for '{validated_sheet_name}'.\")\r\n                    return True\r\n\r\n                # Unpack remaining data and define styles for valid report types.\r\n                data_headers = sheet_config.get('headers', [])\r\n                data_columns = sheet_config.get('columns', [])\r\n                fills = { \r\n                    \"header\": PatternFill(start_color=theme_config['header_color'], fill_type='solid'), \r\n                    \"summary\": PatternFill(start_color=theme_config['summary_background'], fill_type='solid'), \r\n                    \"stripe\": PatternFill(start_color=theme_config['stripe_background'], fill_type='solid'), \r\n                    \"changed_a\": PatternFill(start_color=CHANGED_HIGHLIGHT_COLOR_A, fill_type='solid'),\r\n                    \"changed_b\": PatternFill(start_color=CHANGED_HIGHLIGHT_COLOR_B, fill_type='solid')\r\n                }\r\n                fonts = {\"header\": Font(bold=True, color=\"FFFFFF\"), \"bold\": Font(bold=True), \"italic\": Font(italic=True)}\r\n                center_align, right_align = Alignment(horizontal='center', vertical='center'), Alignment(horizontal='right', vertical='center')\r\n\r\n                # --- Logic for 'Simple' Report Type ---\r\n                if report_type == 'Simple':\r\n                    summary_header_data = sheet_config.get('summary_header')\r\n                    start_col = 2 if summary_header_data else 1\r\n                    data_start_row = 8 if summary_header_data else 1\r\n                    if summary_header_data:\r\n                        title_cell = ws.cell(row=1, column=1, value=\"Execution Summary\"); title_cell.font = fonts['bold']; title_cell.alignment = center_align; ws.merge_cells(start_row=1, start_column=1, end_row=1, end_column=2)\r\n                        for r_idx, (key, value) in enumerate(summary_header_data.items(), 2):\r\n                            ws.cell(row=r_idx, column=1, value=key).font = fonts['bold']; ws.cell(row=r_idx, column=2, value=safe_cell_value(value))\r\n                        for row in ws.iter_rows(min_row=1, max_row=len(summary_header_data) + 1, min_col=1, max_col=2):\r\n                            for cell in row: cell.fill = fills['summary']\r\n                    if data_headers:\r\n                        for i, value in enumerate(data_headers, start_col): ws.cell(row=data_start_row, column=i, value=value).font, ws.cell(row=data_start_row, column=i, value=value).fill, ws.cell(row=data_start_row, column=i, value=value).alignment = fonts['header'], fills['header'], center_align\r\n                        num_rows = len(data_columns[0]) if data_columns and data_columns[0] else 0\r\n                        for i in range(num_rows):\r\n                            for j, col in enumerate(data_columns, start_col): \r\n                                cell_value = safe_cell_value(col[i] if i < len(col) else \"\")\r\n                                cell = ws.cell(row=data_start_row + 1 + i, column=j, value=cell_value)\r\n                                # Apply center alignment for individual parameter-like data\r\n                                if should_center_align_data(cell_value):\r\n                                    cell.alignment = center_align\r\n                        \r\n                        end_col_idx = start_col + len(data_headers) - 1\r\n                        \r\n                        # Manually apply row striping for better file integrity\r\n                        if num_rows > 0:\r\n                            data_rows_for_styling = ws.iter_rows(min_row=data_start_row + 1, max_row=data_start_row + 1 + num_rows -1, min_col=start_col, max_col=end_col_idx)\r\n                            for i, row_obj in enumerate(data_rows_for_styling):\r\n                                if (i + 1) % 2 == 0:\r\n                                    for cell in row_obj:\r\n                                        cell.fill = fills['stripe']\r\n\r\n                        table_range_str = f\"{get_column_letter(start_col)}{data_start_row}:{get_column_letter(end_col_idx)}{data_start_row + num_rows}\"\r\n                        safe_table_name = create_safe_table_name(validated_sheet_name)\r\n                        table = Table(displayName=safe_table_name, ref=table_range_str); table.tableStyleInfo = TableStyleInfo(name=BASE_TABLE_STYLE, showFirstColumn=False, showLastColumn=False, showRowStripes=False, showColumnStripes=False); ws.add_table(table)\r\n                \r\n                # --- Logic for 'Comparison' Report Type ---\r\n                elif report_type == 'Comparison':\r\n                    report_data, stats = process_element_data(data_columns, data_headers, logger)\r\n                    report_headers = data_headers + [\"Update Status\"]\r\n                    total_changed_counter[0] += stats['changed']\r\n                    \r\n                    suppress_highlighting = stats['changed'] > 0 and stats['changed'] == stats['total']\r\n                    if suppress_highlighting: logger.log(\"All rows have changed; suppressing yellow highlight for clarity on first run.\")\r\n                    \r\n                    ws['A1'] = \"Report Summary\"; ws['A1'].font = fonts['bold']; ws.merge_cells('A1:B1'); ws['A1'].alignment = center_align\r\n                    summary_data = {\"Total Rows:\": stats['total'], \"Changed:\": stats['changed'], \"No Change:\": stats['no_change'], \"Errors:\": stats['errors']}\r\n                    for i, (key, value) in enumerate(summary_data.items(), 2): ws.cell(row=i, column=1, value=key).font = fonts['bold']; ws.cell(row=i, column=2, value=value).alignment = right_align\r\n                    timestamp_str = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\"); ws.merge_cells('A6:B6'); ws['A6'].value = f\"Generated: {timestamp_str}\"; ws['A6'].font = fonts['italic']; ws['A6'].alignment = center_align\r\n                    for row in ws['A1:B6']:\r\n                        for cell in row: cell.fill = fills['summary']\r\n                    \r\n                    data_start_row = 8\r\n                    for i, value in enumerate(report_headers, 1): cell = ws.cell(row=data_start_row, column=i, value=value); cell.font, cell.fill, cell.alignment = fonts['header'], fills['header'], center_align\r\n                    for i, row_info in enumerate(report_data):\r\n                        for j, value in enumerate(row_info['data'], 1): ws.cell(row=data_start_row + 1 + i, column=j, value=safe_cell_value(value)).alignment = center_align\r\n                    \r\n                    if report_data:\r\n                        data_rows = ws.iter_rows(min_row=data_start_row + 1, max_row=ws.max_row, min_col=1, max_col=len(report_headers))\r\n                        changed_row_counter = 0\r\n                        for i, row_obj in enumerate(data_rows):\r\n                            if (i + 1) % 2 == 0:\r\n                                for cell in row_obj: cell.fill = fills['stripe']\r\n                            if not suppress_highlighting and report_data[i]['changed']:\r\n                                highlight_fill = fills['changed_a'] if changed_row_counter % 2 == 0 else fills['changed_b']\r\n                                for cell in row_obj: cell.fill = highlight_fill\r\n                                changed_row_counter += 1\r\n                        \r\n                        table_range_str = f\"A{data_start_row}:{get_column_letter(len(report_headers))}{data_start_row + len(report_data)}\"\r\n                        safe_table_name = create_safe_table_name(validated_sheet_name); counter = 1\r\n                        while safe_table_name in used_table_names: safe_table_name = f\"{safe_table_name}{counter}\"; counter += 1\r\n                        used_table_names.add(safe_table_name)\r\n                        table = Table(displayName=safe_table_name, ref=table_range_str); table.tableStyleInfo = TableStyleInfo(name=BASE_TABLE_STYLE, showFirstColumn=False, showLastColumn=False, showRowStripes=False, showColumnStripes=False); ws.add_table(table)\r\n                        ws.freeze_panes = ws.cell(row=data_start_row + 1, column=1); logger.log(f\"Table '{safe_table_name}' created for Comparison report.\")\r\n                \r\n                # --- Column Auto-Sizing Logic (for valid reports) ---\r\n                column_widths = {}\r\n                for row in ws.rows:\r\n                    for cell in row:\r\n                        if cell.value:\r\n                            adjusted_len = (len(str(cell.value)) * 1.15) + 1\r\n                            column_widths[cell.column] = max(column_widths.get(cell.column, 0), adjusted_len)\r\n                \r\n                for col_idx, max_len in column_widths.items():\r\n                    ws.column_dimensions[get_column_letter(col_idx)].width = min(max_len, MAX_COLUMN_WIDTH)\r\n                \r\n                logger.log(\"Auto-sized columns successfully.\"); return True\r\n            except Exception as e:\r\n                logger.error(f\"Failed to process sheet '{validated_sheet_name or 'Unknown'}': {e}\\n{traceback.format_exc()}\"); return False\r\n\r\n        def create_multi_sheet_excel_report(filepath, sheet_configs, logger, theme_config, total_changed_counter):\r\n            \"\"\"\r\n            Main function to orchestrate the creation of the Excel workbook.\r\n            It validates the filepath, creates sheets, adds a log sheet, and saves the file.\r\n            \"\"\"\r\n            is_path_valid, validated_filepath, is_default_path = validate_filepath(filepath, logger)\r\n            if not is_path_valid: return False, \"Filepath validation failed.\"\r\n            \r\n            try:\r\n                wb = openpyxl.Workbook(); wb.remove(wb.active)\r\n                used_sheet_names, used_table_names, sheet_count = set(), set(), 0\r\n                \r\n                for config in sheet_configs:\r\n                    original_name = config.get('name', 'Report Sheet'); validated_name = validate_sheet_name(original_name, logger); final_name = validated_name; counter = 1\r\n                    while final_name in used_sheet_names: \r\n                        suffix = f\"_{counter}\"; final_name = validated_name[:MAX_SHEET_NAME_LENGTH - len(suffix)] + suffix; counter += 1\r\n                    if final_name != original_name: logger.warning(f\"Sheet '{original_name}' renamed to '{final_name}' for uniqueness.\")\r\n                    config['name'] = final_name; used_sheet_names.add(final_name)\r\n                    if process_and_create_sheet(wb, config, logger, used_table_names, theme_config, total_changed_counter): sheet_count += 1\r\n                \r\n                if sheet_count == 0: logger.warning(\"No data sheets were created. Report will only contain the script log.\")\r\n                \r\n                # --- Create and Format the Log Sheet ---\r\n                log_ws = wb.create_sheet(title=\"Script Log\"); log_ws.append([\"Timestamp\", \"Elapsed (s)\", \"Level\", \"Message\"]); log_pattern = re.compile(r\"\\[(.*?)\\]\\[(.*?)s\\]\\[(.*?)\\] (.*)\", re.DOTALL)\r\n                for msg in logger.get_messages():\r\n                    match = log_pattern.match(msg)\r\n                    if match: log_ws.append([match.group(1), float(match.group(2)), match.group(3), match.group(4)])\r\n                    else: log_ws.append([\"\", \"\", \"\", msg])\r\n                header_fill = PatternFill(start_color=theme_config['log_header_color'], fill_type='solid'); stripe_fill, error_fill, warning_fill = PatternFill(start_color='FFEAEAEA', fill_type='solid'), PatternFill(start_color='FFFFC7CE', fill_type='solid'), PatternFill(start_color='FFFFEB9C', fill_type='solid'); header_font, header_align, data_align, indent_align = Font(bold=True, color=\"FFFFFF\"), Alignment(horizontal='center', vertical='center'), Alignment(horizontal='center', vertical='center'), Alignment(horizontal='left', vertical='top', indent=1, wrap_text=True)\r\n                for cell in log_ws[\"1:1\"]: cell.font, cell.fill, cell.alignment = header_font, header_fill, header_align\r\n                for row_num in range(2, log_ws.max_row + 1):\r\n                    fill = stripe_fill if row_num % 2 == 0 else None\r\n                    level = log_ws.cell(row=row_num, column=3).value\r\n                    if level == \"ERROR\": fill = error_fill\r\n                    elif level == \"WARN\": fill = warning_fill\r\n                    for col_num in range(1, 5): log_ws.cell(row=row_num, column=col_num).alignment = data_align if col_num < 4 else indent_align\r\n                    if fill:\r\n                        for col_num in range(1, 5): log_ws.cell(row=row_num, column=col_num).fill = fill\r\n                log_ws.column_dimensions['A'].width, log_ws.column_dimensions['B'].width, log_ws.column_dimensions['C'].width, log_ws.column_dimensions['D'].width = 12, 12, 10, 100; log_ws.freeze_panes = 'A2'\r\n                \r\n                # --- Save the Workbook ---\r\n                final_filepath = validated_filepath; logger.log(f\"Attempting to save workbook to: {final_filepath}\")\r\n                if is_default_path:\r\n                    wb.save(filename=final_filepath)\r\n                else:\r\n                    try: \r\n                        wb.save(filename=final_filepath)\r\n                    except PermissionError:\r\n                        logger.warning(f\"SAVE FAILED: '{os.path.basename(final_filepath)}' is open or permission is denied.\")\r\n                        p = Path(validated_filepath); final_filepath = p.with_name(f\"{p.stem}_{datetime.now().strftime('%Y%m%d_%H%M%S')}{p.suffix}\"); logger.log(f\"Attempting to save to a new file: {final_filepath}\"); wb.save(filename=final_filepath)\r\n                \r\n                if platform.system() == \"Windows\": os.startfile(final_filepath)\r\n                return True, f\"Excel report with {sheet_count} sheet(s) created: {os.path.basename(final_filepath)}\"\r\n            except Exception as e:\r\n                error_msg = f\"An unexpected error occurred: {e}\"; logger.error(f\"{error_msg}\\n{traceback.format_exc()}\"); return False, error_msg\r\n\r\n        def main():\r\n            \"\"\"\r\n            The main entry point for the script.\r\n            It parses inputs, builds sheet configurations, and calls the report creation function.\r\n            \"\"\"\r\n            try:\r\n                # --- Input Parsing and Validation ---\r\n                if len(IN) < 3: raise ValueError(\"Insufficient inputs. Expected filepath, sheet_names, and theme.\")\r\n                filepath, sheet_names, theme_input, data_packages = IN[0], IN[1], IN[2], IN[3:]\r\n                theme_config = get_theme_config(theme_input, logger)\r\n                sheet_names = [sheet_names] if isinstance(sheet_names, str) else sheet_names\r\n                if not isinstance(sheet_names, list): raise TypeError(f\"Sheet names (IN[1]) must be a list.\")\r\n                num_names, num_packages = len(sheet_names), len(data_packages)\r\n                if num_names != num_packages:\r\n                    sheets_to_process = min(num_names, num_packages); logger.warning(f\"Input Mismatch: Found {num_names} names and {num_packages} data packages. Processing {sheets_to_process} sheets.\")\r\n                else: \r\n                    sheets_to_process = num_names\r\n                \r\n                total_changed_counter = [0]\r\n                sheet_configs = []\r\n                \r\n                # --- Sheet Configuration Assembly ---\r\n                for i in range(sheets_to_process):\r\n                    sheet_name, package = sheet_names[i], data_packages[i]\r\n                    headers, data_columns, error = normalize_data_package(package, logger)\r\n                    \r\n                    if error:\r\n                        logger.error(f\"Data for sheet '{sheet_name}' is invalid. Creating a placeholder sheet. Reason: {error}\")\r\n                        config = {\r\n                            'name': sheet_name,\r\n                            'type': 'Error', \r\n                            'error_message': f\"The data package provided for this sheet was null or in an unrecognized format. See the Script Log tab for details.\"\r\n                        }\r\n                    else:\r\n                        is_sow_log_report = isinstance(package, dict) and 'debug_log' in package\r\n                        config = {'name': sheet_name, 'headers': headers, 'columns': data_columns}\r\n                        header_string = ' '.join(str(h) for h in headers).lower()\r\n                        \r\n                        if is_sow_log_report:\r\n                            logger.log(f\"Classifying '{sheet_name}' as a Simple/Log report.\")\r\n                            config['type'] = 'Simple'\r\n                            summary_data = {k: (v[0] if isinstance(v, list) and len(v)==1 else v) for k, v in package.items() if k != 'debug_log'}\r\n                            log_data = package.get('debug_log', [])\r\n                            config['summary_header'] = summary_data; config['headers'] = ['Log Messages']; config['columns'] = [log_data]\r\n                        elif 'original' in header_string and 'updated' in header_string:\r\n                            logger.log(f\"Classifying '{sheet_name}' as a Comparison report.\"); config['type'] = 'Comparison'\r\n                        else:\r\n                            logger.log(f\"Classifying '{sheet_name}' as a Simple report.\"); config['type'] = 'Simple'; config['summary_header'] = None\r\n                    \r\n                    sheet_configs.append(config)\r\n                    \r\n                logger.log(f\"Successfully assembled {len(sheet_configs)} sheet configurations.\")\r\n                if not sheet_configs:\r\n                    logger.warning(\"No sheet names provided. Report will only contain logs.\")\r\n                \r\n                success, message = create_multi_sheet_excel_report(filepath, sheet_configs, logger, theme_config, total_changed_counter)\r\n                if success: logger.log(\"Script completed successfully.\")\r\n                else: logger.error(\"Script completed with errors.\")\r\n                return [message, logger.get_messages(), str(total_changed_counter[0])]\r\n            except Exception as e:\r\n                error_msg = f\"Fatal error in main execution: {e}\\n{traceback.format_exc()}\"\r\n                logger.error(error_msg); return [error_msg, logger.get_messages(), \"0\"]\r\n\r\n        OUT = main()",
      "Engine": "CPython3",
      "EngineName": "CPython3",
