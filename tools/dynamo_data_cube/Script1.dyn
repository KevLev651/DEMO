      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "NodeType": "CodeBlockNode",
      "Code": "// Graph 1 - Insert & Locate Connectors\n// Extractor Configuration\n\n\"Main\";\n // OUT[0] -> Extractor.IN[1];\n\n// Full 9-field mapping — feeds BOTH Extractor (validation) and ConMan inline writes\n[\n    [\"Equipment ID\",           \"Equipment ID\"],\n    [\"Equipment Description\",  \"Equipment Description\"],\n    [\"Connection ID\",          \"Connection ID\"],\n    [\"Equipment Condition\",    \"Condition\"],\n    [\"Voltage & Phase\",        \"System Voltage\"],\n    [\"Connection Size\",        \"Nominal Diameter\"],\n    [\"Functional Area\",        \"Functional Area\"],\n    [\"Line Number\",            \"Line Designator\"],\n    [\"Service\",                \"Service\"]\n];\n // OUT[1] -> Extractor.IN[2];\n\n4;\n // OUT[2] -> Extractor.IN[3];\n\n[\"Connection ID\",\n    [\n        \"CA\", \"DRN\", \"EL\", \"EX\", \"HH\",\n        \"INT\", \"PCW\", \"PHW\", \"TD\"\n    ]\n];\n // OUT[3] -> Extractor.IN[4];\n\n{\n    \"logic\": \"AND\",\n    \"filters\": [[\"Obsolete\", [\"\"]]]\n};\n // OUT[4] -> Extractor.IN[5];",
      "Id": "7359c054c20c40e8ab450ecb03ab2925",
      "Inputs": [],
      "Outputs": [
