      "Code": "\"Equipment ID\";\n// Anchor parameter name;\n\n[\n\"Data Devices\",\n\"Electrical Equipment\",\n\"Mechanical Equipment\"\n];\n// Revit categories to search for existing connectors;\n\n// Insertion config: [filter_param, [[prefix, family_name], ...]];\n[\"Connection ID\",\n    [\n        [\"CA\",  \"Process Pipe Connector\"],\n        [\"DRN\", \"Process Pipe Connector\"],\n        [\"EL\",  \"Process Electrical Connector\"],\n        [\"EX\",  \"Process Duct Connector\"],\n        [\"HH\",  \"Process Pipe Connector\"],\n        [\"INT\", \"Process Duct Connector\"],\n        [\"PCW\", \"Process Pipe Connector\"],\n        [\"PHW\", \"Process Pipe Connector\"],\n        [\"TD\",  \"Process Data Connector\"]\n    ]\n];",
