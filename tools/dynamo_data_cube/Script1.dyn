      "Code": "// Parameter Writer Config\n\n// OUT[0]: Categories\n[\n    \"Electrical Equipment\",\n    \"Data Devices\",\n    \"Mechanical Equipment\",\n    \"Generic Models\"\n];\n\n// OUT[1]: Key parameter\n\"Connection ID\";",
      "Id": "c63b908678d3433483bf5f432e01e56a",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "11df6d0f07474350bf86d62fe9c2e748",
