    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# ConMan\n# Connector Manager for Process Data Cubes\n# Revit 2023 / Dynamo 2.16 / CPython3\n# Developed By - Chris Staker & Kevin Levasseur\n# v3.0.0 - Replaced static param_mapping with UM-Revit Mapping read from Excel.\n#           Initial param writes on new inserts now use read_um_revit_mapping()\n#           with family applicability checks and unlisted-family fallback,\n#           matching Script 2 v9.9.0 logic.\n\nimport sys\nimport clr\nimport re\n\nfrom System.Collections.Generic import List\n\nclr.AddReference('RevitAPI')\nimport Autodesk.Revit.DB as DB\nfrom Autodesk.Revit.DB import (XYZ, ElementId, FilteredElementCollector,\n    BuiltInParameter, BuiltInCategory, ElementMulticategoryFilter,\n    FamilySymbol, LocationPoint)\nimport Autodesk.Revit.DB.Structure as DBStruct\n\nclr.AddReference('RevitServices')\nimport RevitServices\nfrom RevitServices.Persistence import DocumentManager\nfrom RevitServices.Transactions import TransactionManager\n\n# Inputs\nanchor_param_name = IN[0]\ntarget_categories  = IN[1]\nif isinstance(target_categories, str): target_categories = [target_categories]\n\ninsertion_config = IN[2]\nscript1_output   = IN[3]\nraw = IN[4] if len(IN) > 4 else True\nmove_enabled = bool(raw[0]) if isinstance(raw, list) else bool(raw)\nexcel_file_path  = IN[5] if len(IN) > 5 else None   # was param_mapping\n\ndoc = DocumentManager.Instance.CurrentDBDocument\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 1 — HELPER FUNCTIONS\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef safe_get(obj, key, default=None):\n    try:\n        if hasattr(obj, \"get\"):\n            val = obj.get(key)\n            return val if val is not None else default\n        elif hasattr(obj, \"ContainsKey\"):\n            if obj.ContainsKey(key):\n                val = obj[key]\n                return val if val is not None else default\n        elif hasattr(obj, \"Keys\"):\n            for k in obj.Keys:\n                if str(k) == str(key):\n                    val = obj.GetValueAtKey(k) if hasattr(obj, \"GetValueAtKey\") else obj[k]\n                    return val if val is not None else default\n    except: pass\n    return default\n\ndef get_param_value(elem, name):\n    p = elem.LookupParameter(name)\n    if p:\n        if p.StorageType == DB.StorageType.Double: return p.AsDouble()\n        elif p.StorageType == DB.StorageType.Integer: return p.AsInteger()\n        else: return p.AsString()\n    return None\n\ndef get_family_name(elem):\n    try:\n        fn_p = elem.Symbol.get_Parameter(BuiltInParameter.SYMBOL_FAMILY_NAME_PARAM)\n        return fn_p.AsString() if fn_p else \"\"\n    except:\n        return \"\"\n\ndef build_param_map(elem_or_type):\n    \"\"\"Returns a lowercase-name → parameter dict.\"\"\"\n    pm = {}\n    if not elem_or_type: return pm\n    try:\n        for p in elem_or_type.Parameters:\n            try: pm[p.Definition.Name.strip().lower()] = p\n            except: pass\n    except: pass\n    return pm\n\ndef set_location(elem, new_xyz):\n    try:\n        loc = elem.Location\n        if isinstance(loc, LocationPoint):\n            old_pt = loc.Point\n            old_str = \"X:{:.2f}, Y:{:.2f}, Z:{:.2f}\".format(old_pt.X, old_pt.Y, old_pt.Z)\n            if not old_pt.IsAlmostEqualTo(new_xyz, 0.0026):\n                loc.Point = new_xyz\n                return True, old_str\n            return False, old_str\n        return False, \"N/A\"\n    except: return False, \"Error\"\n\ndef extract_flat_data(data_input):\n    flat_data = safe_get(data_input, \"FlatData\")\n    if flat_data is not None:\n        return flat_data\n    is_list_like = isinstance(data_input, list) or (hasattr(data_input, '__iter__') and not isinstance(data_input, str) and not hasattr(data_input, 'ContainsKey') and not hasattr(data_input, 'keys'))\n    if is_list_like:\n        flat = []\n        for item in data_input:\n            is_item_list = isinstance(item, list) or (hasattr(item, '__iter__') and not isinstance(item, str) and not hasattr(item, 'ContainsKey') and not hasattr(item, 'keys'))\n            if is_item_list:\n                flat.extend(extract_flat_data(item))\n            else:\n                if safe_get(item, \"Excel Header\") is None and safe_get(item, \"Log\") is None:\n                    flat.append(item)\n        return flat\n    return [data_input] if (hasattr(data_input, 'keys') or hasattr(data_input, 'ContainsKey')) else []\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 2 — UM-REVIT MAPPING READER  (matches Script 2 v9.9.0)\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef read_um_revit_mapping(file_path):\n    \"\"\"\n    Reads the UM-Revit Mapping sheet from the Utility Matrix Excel file.\n    Returns dict keyed by lowercase Excel column name:\n      { \"connection size\": {\"params\": [...], \"families\": [...]} }\n    Entries with no \"Yes\" in any family column are excluded.\n    \"\"\"\n    um_map = {}\n    if not file_path:\n        return um_map\n    try:\n        _pkg_paths = [\n            r\"C:\\Dynamo\\2.16\\Python Support Pckg\",\n            r\"K:\\CAD\\_Revit2023\\Add_Ins\\Python Support Pckg\",\n        ]\n        for _p in _pkg_paths:\n            import os as _os\n            if _os.path.isdir(_p) and _p not in sys.path:\n                sys.path.insert(0, _p)\n                break\n        from openpyxl import load_workbook\n        wb = load_workbook(file_path, read_only=True, data_only=True)\n        if 'UM-Revit Mapping' not in wb.sheetnames:\n            wb.close()\n            return um_map\n\n        ws = wb['UM-Revit Mapping']\n        header_row  = [c.value for c in next(ws.iter_rows(min_row=3, max_row=3))]\n        family_cols = [str(h).strip() for h in header_row[2:] if h]\n\n        for row in ws.iter_rows(min_row=4, values_only=True):\n            excel_col   = row[0]\n            revit_param = row[1]\n            if not excel_col or not revit_param:\n                continue\n            key         = str(excel_col).strip().lower()\n            params_list = [p.strip() for p in str(revit_param).strip().split(',') if p.strip()]\n\n            applicable = []\n            for i, fam_name in enumerate(family_cols):\n                col_idx = i + 2\n                if col_idx < len(row):\n                    cell_val = row[col_idx]\n                    if cell_val and str(cell_val).strip().lower() == \"yes\":\n                        applicable.append(fam_name)\n\n            if not applicable:\n                continue   # No \"Yes\" for any family — skip\n\n            if key not in um_map:\n                um_map[key] = {\"params\": [], \"families\": set()}\n            for p in params_list:\n                if p not in um_map[key][\"params\"]:\n                    um_map[key][\"params\"].append(p)\n            for f in applicable:\n                um_map[key][\"families\"].add(f)\n\n        wb.close()\n        for k in um_map:\n            um_map[k][\"families\"] = list(um_map[k][\"families\"])\n\n    except Exception:\n        pass\n\n    return um_map\n\n\ndef family_is_applicable(elem_family_name, applicable_families):\n    \"\"\"\n    Substring match (case-insensitive) of elem_family_name against applicable_families.\n    Returns True if any entry matches, or if applicable_families is empty.\n    \"\"\"\n    if not applicable_families:\n        return True\n    efn = elem_family_name.strip().lower()\n    for fam in applicable_families:\n        fam_lower = fam.strip().lower()\n        if fam_lower in efn or efn in fam_lower:\n            return True\n    return False\n\n\ndef write_params_via_um_mapping(inst, excel_row, um_revit_map):\n    \"\"\"\n    Write parameters to a newly inserted connector element using the UM-Revit\n    Mapping. Applies family applicability checks with the same unlisted-family\n    fallback used in Script 2 v9.9.0: if the family is not in the mapping but\n    the mapped parameter physically exists on the element, allow the write.\n    Called inside an open transaction.\n    \"\"\"\n    if not um_revit_map:\n        return\n    elem_fn  = get_family_name(inst)\n    inst_pm  = build_param_map(inst)\n    el_type  = doc.GetElement(inst.GetTypeId())\n    type_pm  = build_param_map(el_type) if el_type else {}\n\n    for col_lower, mapping_entry in um_revit_map.items():\n        val = safe_get(excel_row, col_lower)\n        if val is None or str(val).strip() in ('', '-', 'None', 'null'):\n            continue\n\n        revit_param_names   = mapping_entry['params']\n        applicable_families = mapping_entry['families']\n\n        # Applicability check — with fallback for families not in the mapping\n        if applicable_families and not family_is_applicable(elem_fn, applicable_families):\n            param_exists = any(\n                inst_pm.get(rpn.strip().lower()) is not None or\n                type_pm.get(rpn.strip().lower()) is not None\n                for rpn in revit_param_names\n            )\n            if not param_exists:\n                continue  # Param genuinely not on this element — skip\n\n        for rpn in revit_param_names:\n            p = inst_pm.get(rpn.strip().lower())\n            if p and not p.IsReadOnly:\n                val_str = str(val).strip()\n                try:\n                    if p.StorageType == DB.StorageType.String:\n                        p.Set(val_str.upper())\n                    elif p.StorageType == DB.StorageType.Double:\n                        if not p.SetValueString(val_str):\n                            try: p.Set(float(val))\n                            except: pass\n                    elif p.StorageType == DB.StorageType.Integer:\n                        try: p.Set(int(float(val)))\n                        except: pass\n                except: pass\n\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 3 — METRICS & REPORT SETUP\n# ═══════════════════════════════════════════════════════════════════════════════\n\nmetrics = {\n    \"Total Cubes\": 0, \"Excel Conns\": 0, \"Model Conns\": 0,\n    \"Moved\": 0, \"Inserted\": 0, \"Skipped\": 0,\n    \"Rogues Detected\": [], \"Errors\": []\n}\nreport_data = [[\"Revit Element ID\", \"Action\", \"Equipment ID\",\n                \"Connection ID\", \"Previous Location\", \"New Location\"]]\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 4 — DATA PREPARATION\n# ═══════════════════════════════════════════════════════════════════════════════\n\nexcel_data = extract_flat_data(script1_output)\nif not excel_data:\n    OUT = [[\"Error: Invalid data structure from Script 1.\"]], [[\"Metric\", \"Value\"]]\n    sys.exit()\n\nfilter_param_revit = insertion_config[0]\nfilter_param_excel = filter_param_revit.strip().lower()\nfilter_rules       = insertion_config[1]\nanchor_param_excel = anchor_param_name.strip().lower()\n\nreq_map = {}\nfor row in excel_data:\n    val = str(safe_get(row, filter_param_excel, \"\")).strip()\n    if val not in [\"-\", \"None\", \"\", \"null\"]:\n        metrics[\"Excel Conns\"] += 1\n        eid_key = str(safe_get(row, anchor_param_excel, \"\")).strip().upper()\n        if eid_key not in req_map: req_map[eid_key] = []\n        req_map[eid_key].append(row)\n\ncubes_coll = FilteredElementCollector(doc).OfCategory(BuiltInCategory.OST_GenericModel).WhereElementIsNotElementType().ToElements()\ndata_cubes = [c for c in cubes_coll if \"Process Data Cube - Generic\" in c.Symbol.Family.Name]\nmetrics[\"Total Cubes\"] = len(data_cubes)\n\ncat_map = {}\nfor c_name in target_categories:\n    for cat in doc.Settings.Categories:\n        if cat.Name == c_name:\n            cat_map[cat.Id] = c_name\n            break\n\nexisting_connectors = []\nif cat_map:\n    typed_ids = List[ElementId](cat_map.keys())\n    multi_filter = ElementMulticategoryFilter(typed_ids)\n    raw_conns = FilteredElementCollector(doc).WherePasses(multi_filter).WhereElementIsNotElementType().ToElements()\n    existing_connectors = [e for e in raw_conns if \"Connector\" in e.Symbol.Family.Name]\nmetrics[\"Model Conns\"] = len(existing_connectors)\n\nsymbol_cache = {}\nfor ec in existing_connectors:\n    try:\n        symbol = ec.Symbol\n        fn_p = symbol.get_Parameter(BuiltInParameter.SYMBOL_FAMILY_NAME_PARAM)\n        family_name = fn_p.AsString() if fn_p else \"\"\n        if family_name and family_name not in symbol_cache:\n            symbol_cache[family_name] = symbol.Id\n    except: continue\n\ntarget_search_terms = set(str(rule[1]).strip().lower() for rule in filter_rules if len(rule) > 1)\nfor fs in FilteredElementCollector(doc).OfClass(FamilySymbol):\n    try:\n        fn_p = fs.get_Parameter(BuiltInParameter.SYMBOL_FAMILY_NAME_PARAM)\n        fn = fn_p.AsString() if fn_p else \"\"\n        if any(term in fn.lower() for term in target_search_terms):\n            if fn and fn not in symbol_cache:\n                symbol_cache[fn] = fs.Id\n    except: continue\n\ndef get_symbol_id_from_cache(target_name):\n    t_clean = target_name.strip().lower()\n    for fam_name, sym_id in symbol_cache.items():\n        if t_clean == fam_name.lower(): return sym_id\n    for fam_name, sym_id in symbol_cache.items():\n        if t_clean in fam_name.lower(): return sym_id\n    return None\n\nconn_map = {}\nconn_by_connection_id = {}\nfor ec in existing_connectors:\n    eid = get_param_value(ec, anchor_param_name)\n    if eid:\n        key = str(eid).strip().upper()\n        if key not in conn_map: conn_map[key] = []\n        conn_map[key].append(ec)\n        conn_id_val = str(get_param_value(ec, filter_param_revit) or \"\").strip().upper()\n        if conn_id_val and conn_id_val not in [\"-\", \"NONE\", \"\", \"NULL\"]:\n            if key not in conn_by_connection_id: conn_by_connection_id[key] = {}\n            conn_by_connection_id[key][conn_id_val] = ec\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 5 — BUILD QUEUE\n# ═══════════════════════════════════════════════════════════════════════════════\n\nfull_queue = []\n\nfor cube in data_cubes:\n    eid_raw = get_param_value(cube, anchor_param_name)\n    if not eid_raw: continue\n    eid_key = str(eid_raw).strip().upper()\n\n    cube_reqs   = req_map.get(eid_key, [])\n    model_conns = conn_map.get(eid_key, [])\n    conn_lookup = conn_by_connection_id.get(eid_key, {})\n    if not cube_reqs and not model_conns: continue\n\n    f,  bk = get_param_value(cube, \"Offset Front\") or 0.0, get_param_value(cube, \"Offset Back\")  or 0.0\n    l,  r  = get_param_value(cube, \"Offset Left\")  or 0.0, get_param_value(cube, \"Offset Right\") or 0.0\n    t      = get_param_value(cube, \"Offset Top\")   or 0.0\n    length_dim, width_dim = abs(f) + abs(bk), abs(l) + abs(r)\n    lx, ly, lz = (r - l) / 2.0, (f - bk) / 2.0, t\n\n    unified_queue      = []\n    consumed_model_ids = set()\n\n    for row in cube_reqs:\n        conn_id       = str(safe_get(row, filter_param_excel, \"\")).strip()\n        conn_id_upper = conn_id.upper()\n        target_fam    = next((f_name for f_text, f_name in filter_rules if f_text.lower() in conn_id.lower()), None)\n        if not target_fam: continue\n        if conn_id_upper in conn_lookup:\n            ec = conn_lookup[conn_id_upper]\n            unified_queue.append([ec, 0, conn_id, row])\n            consumed_model_ids.add(ec.Id)\n        else:\n            symbol_id = get_symbol_id_from_cache(target_fam)\n            if symbol_id:\n                unified_queue.append([symbol_id, 1, conn_id, row])\n            else:\n                metrics[\"Errors\"].append(\"ID {}: Missing family '{}'\".format(eid_key, target_fam))\n\n    for ec in model_conns:\n        if ec.Id not in consumed_model_ids:\n            unified_queue.append([ec, 2, None, None])\n            cat_name = cat_map.get(ec.Category.Id, \"Unknown\")\n            r_type = (\"Data\" if cat_name == \"Data Devices\" else\n                      \"Electrical\" if cat_name == \"Electrical Equipment\" else\n                      \"Duct\" if \"Duct\" in ec.Symbol.Family.Name else \"Pipe\")\n            metrics[\"Rogues Detected\"].append(\"ID {}: Rogue {} (ID: {})\".format(eid_key, r_type, ec.Id))\n\n    total_n = len(unified_queue)\n    if total_n == 0: continue\n\n    is_len       = length_dim >= width_dim\n    axis_dim     = length_dim if is_len else width_dim\n    spacing      = max(0.333, axis_dim / (total_n + 1))\n    start_offset = -((total_n - 1) * spacing) / 2.0\n    trans        = cube.GetTransform()\n\n    for i, (item, type_code, val, excel_row) in enumerate(unified_queue):\n        if type_code == 2: continue\n        step     = start_offset + (i * spacing)\n        local_pt = XYZ(lx, ly + step, lz) if is_len else XYZ(lx + step, ly, lz)\n        world_pt = trans.OfPoint(local_pt)\n        full_queue.append([item, type_code, val, eid_raw, excel_row, world_pt, cube])\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 6 — TRANSACTION 1: INSERT & MOVE\n# ═══════════════════════════════════════════════════════════════════════════════\n\nTransactionManager.Instance.EnsureInTransaction(doc)\napp_create = doc.Create\ninserted_items = []  # [(new_inst, excel_row, eid_raw, val, new_loc_str)]\n\nfor item, type_code, val, eid_raw, excel_row, world_pt, cube in full_queue:\n    new_loc_str = \"X:{:.2f}, Y:{:.2f}, Z:{:.2f}\".format(world_pt.X, world_pt.Y, world_pt.Z)\n    if type_code == 1:\n        try:\n            symbol = doc.GetElement(item)\n            if not symbol.IsActive: symbol.Activate()\n            new_inst = app_create.NewFamilyInstance(world_pt, symbol, cube, DBStruct.StructuralType.NonStructural)\n            new_inst.LookupParameter(anchor_param_name).Set(str(eid_raw))\n            new_inst.LookupParameter(filter_param_revit).Set(str(val))\n            inserted_items.append((new_inst, excel_row, eid_raw, val, new_loc_str))\n            metrics[\"Inserted\"] += 1\n        except Exception as ex:\n            metrics[\"Errors\"].append(\"Insert failed {}: {}\".format(str(eid_raw), str(ex)))\n    elif type_code == 0:\n        if move_enabled:\n            moved, old_loc_str = set_location(item, world_pt)\n            if moved:\n                report_data.append([item.Id.ToString(), \"Moved\", str(eid_raw), str(val), old_loc_str, new_loc_str])\n                metrics[\"Moved\"] += 1\n            else:\n                report_data.append([item.Id.ToString(), \"No Change\", str(eid_raw), str(val), old_loc_str, old_loc_str])\n                metrics[\"Skipped\"] += 1\n        else:\n            loc = item.Location\n            old_loc_str = (\"X:{:.2f}, Y:{:.2f}, Z:{:.2f}\".format(loc.Point.X, loc.Point.Y, loc.Point.Z)\n                           if isinstance(loc, LocationPoint) else \"N/A\")\n            report_data.append([item.Id.ToString(), \"No Change (Move Disabled)\", str(eid_raw), str(val), old_loc_str, old_loc_str])\n            metrics[\"Skipped\"] += 1\n\nTransactionManager.Instance.TransactionTaskDone()\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 7 — REGENERATE + TRANSACTION 2: WRITE PARAMS TO NEW INSERTS\n#\n#   Reads the UM-Revit Mapping from Excel and writes all applicable parameters\n#   to newly inserted connector elements. Uses family applicability checks with\n#   the same unlisted-family fallback as Script 2 v9.9.0.\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndoc.Regenerate()\n\nif inserted_items:\n    um_revit_map = read_um_revit_mapping(excel_file_path)\n    TransactionManager.Instance.EnsureInTransaction(doc)\n    for new_inst, excel_row, eid_raw, val, new_loc_str in inserted_items:\n        try:\n            write_params_via_um_mapping(new_inst, excel_row, um_revit_map)\n            report_data.append([new_inst.Id.ToString(), \"Inserted New\",\n                                 str(eid_raw), str(val), \"N/A\", new_loc_str])\n        except Exception as ex:\n            metrics[\"Errors\"].append(\"Param write failed {}: {}\".format(str(val), str(ex)))\n    TransactionManager.Instance.TransactionTaskDone()\n\nif len(report_data) == 1:\n    report_data = [[\"No connection items processed.\"]]\n\nmetrics_table = [[\"Metric\", \"Value\"]]\nfor key, value in metrics.items():\n    value_str = (\" | \".join(str(v) for v in value) if isinstance(value, list) and value\n                 else \"None\" if isinstance(value, list) else str(value))\n    metrics_table.append([key, value_str])\n\nOUT = [report_data, metrics_table]\n",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
