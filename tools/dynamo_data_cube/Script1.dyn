    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# Script 1 — Parameter Writer\n# Revit 2023 / Dynamo 2.16 / CPython3\n# Developed By - Chris Staker & Kevin Levasseur\n# v1.0.0 - Full rewrite. Replaces static mapping with UM-Revit Mapping read\n#           directly from the Utility Matrix Excel file. Matches Script 2\n#           v9.9.0 logic: existing_connectors element lookup, family\n#           applicability checks, unlisted-family fallback, idempotent writes,\n#           Original/Updated report columns for ExcelGen.\n#\n# INPUTS:\n#   IN[0] = extractor_output   — structured dict from Excel Data Extractor\n#   IN[1] = unused             — legacy (was raw_mapping_table)\n#   IN[2] = categories_input   — list of Revit category name strings\n#   IN[3] = key_parameter      — Revit parameter name for matching (Connection ID)\n#   IN[4] = conman_dependency  — ConMan output (ordering only, not consumed)\n#   IN[5] = excel_file_path    — path to Utility Matrix .xlsx\n\nimport sys\nimport clr\n\nclr.AddReference('RevitAPI')\nfrom Autodesk.Revit.DB import (\n    FilteredElementCollector, StorageType, BuiltInParameter\n)\n\nclr.AddReference('RevitServices')\nimport RevitServices\nfrom RevitServices.Persistence import DocumentManager\nfrom RevitServices.Transactions import TransactionManager\n\ndoc              = DocumentManager.Instance.CurrentDBDocument\nextractor_output = IN[0]\n# IN[1] intentionally not consumed — legacy raw_mapping_table\ncategories_input = IN[2]\nkey_parameter    = IN[3]\n# IN[4] intentionally not consumed — ConMan ordering dependency\nexcel_file_path  = IN[5] if len(IN) > 5 else None\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 1 — HELPER FUNCTIONS  (mirrors Script 2 v9.9.0)\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef safe_get(obj, key, default=None):\n    try:\n        if hasattr(obj, \"get\"):\n            val = obj.get(key)\n            return val if val is not None else default\n        elif hasattr(obj, \"ContainsKey\"):\n            if obj.ContainsKey(key):\n                val = obj[key]\n                return val if val is not None else default\n        elif hasattr(obj, \"Keys\"):\n            for k in obj.Keys:\n                if str(k) == str(key):\n                    val = obj.GetValueAtKey(k) if hasattr(obj, \"GetValueAtKey\") else obj[k]\n                    return val if val is not None else default\n    except: pass\n    return default\n\ndef get_param_display_value(param):\n    if not param: return \"\"\n    st = param.StorageType\n    if st == StorageType.String:\n        return param.AsString() or \"\"\n    elif st == StorageType.Double:\n        try:\n            v = param.AsValueString()\n            if v: return v\n        except: pass\n        return str(round(param.AsDouble(), 4)) if param.AsDouble() is not None else \"\"\n    elif st == StorageType.Integer:\n        return str(param.AsInteger())\n    elif st == StorageType.ElementId:\n        return str(param.AsElementId().IntegerValue)\n    return \"\"\n\ndef check_param_match(param, target_val):\n    if not param or target_val is None: return False\n    st         = param.StorageType\n    target_str = str(target_val).strip()\n    if st == StorageType.String:\n        return (param.AsString() or \"\").strip().upper() == target_str.upper()\n    elif st == StorageType.Double:\n        revit_str = param.AsValueString()\n        if revit_str:\n            if revit_str == target_str:        return True\n            if revit_str == target_str + '\"':  return True\n            if revit_str == target_str + \"'\":  return True\n        try:\n            if param.AsDouble() is not None and abs(param.AsDouble() - float(target_val)) < 0.0001:\n                return True\n        except: pass\n        return False\n    elif st == StorageType.Integer:\n        try:   return param.AsInteger() == int(float(target_val))\n        except: return False\n    return False\n\ndef compare_and_set_param(param, value):\n    \"\"\"Idempotent setter — writes only when value differs from current.\"\"\"\n    if not param or param.IsReadOnly or value is None:\n        return False, get_param_display_value(param)\n    st        = param.StorageType\n    value_str = str(value).strip()\n    try:\n        if st == StorageType.String:\n            before_norm = (param.AsString() or \"\").strip().upper()\n            target_norm = value_str.upper()\n            if before_norm == target_norm:\n                return False, param.AsString() or \"\"\n            param.Set(target_norm)\n            return True, param.AsString() or \"\"\n        elif st == StorageType.Double:\n            before = param.AsDouble()\n            if param.SetValueString(value_str):\n                after   = param.AsDouble()\n                changed = (before is None) or (abs(before - after) > 0.0001)\n                return changed, get_param_display_value(param)\n            try:\n                target_float = float(value)\n                if before is not None and abs(before - target_float) < 0.0001:\n                    return False, get_param_display_value(param)\n                param.Set(target_float)\n                after   = param.AsDouble()\n                changed = (before is None) or (abs(before - after) > 0.0001)\n                return changed, get_param_display_value(param)\n            except:\n                return False, get_param_display_value(param)\n        elif st == StorageType.Integer:\n            try:\n                target_int = int(float(value))\n                if param.AsInteger() == target_int:\n                    return False, get_param_display_value(param)\n                param.Set(target_int)\n                changed = param.AsInteger() == target_int\n                return changed, get_param_display_value(param)\n            except:\n                return False, get_param_display_value(param)\n        return False, get_param_display_value(param)\n    except:\n        return False, get_param_display_value(param)\n\ndef extract_flat_data(data_input):\n    flat_data = safe_get(data_input, \"FlatData\")\n    if flat_data is not None:\n        return flat_data\n    is_list_like = (isinstance(data_input, list) or\n                    (hasattr(data_input, '__iter__') and\n                     not isinstance(data_input, str) and\n                     not hasattr(data_input, 'ContainsKey') and\n                     not hasattr(data_input, 'keys')))\n    if is_list_like:\n        flat = []\n        for item in data_input:\n            is_item_list = (isinstance(item, list) or\n                            (hasattr(item, '__iter__') and\n                             not isinstance(item, str) and\n                             not hasattr(item, 'ContainsKey') and\n                             not hasattr(item, 'keys')))\n            if is_item_list:\n                flat.extend(extract_flat_data(item))\n            elif safe_get(item, \"Excel Header\") is None and safe_get(item, \"Log\") is None:\n                flat.append(item)\n        return flat\n    return ([data_input]\n            if (hasattr(data_input, 'keys') or hasattr(data_input, 'ContainsKey'))\n            else [])\n\ndef get_family_name(elem):\n    try:\n        fn_p = elem.Symbol.get_Parameter(BuiltInParameter.SYMBOL_FAMILY_NAME_PARAM)\n        return fn_p.AsString() if fn_p else \"\"\n    except:\n        return \"\"\n\ndef build_param_map(elem_or_type):\n    pm = {}\n    try:\n        for p in elem_or_type.Parameters:\n            try: pm[p.Definition.Name.strip().lower()] = p\n            except: pass\n    except: pass\n    return pm\n\ndef get_representative_display(param_names, inst_pm, type_pm, preferred_name=None):\n    ordered = []\n    if preferred_name:\n        ordered.append(preferred_name.strip().lower())\n    ordered.extend(n.strip().lower() for n in param_names\n                   if n and n.strip().lower() not in ordered)\n    first_display = \"\"\n    for name in ordered:\n        param = inst_pm.get(name) or type_pm.get(name)\n        display = get_param_display_value(param) if param is not None else \"\"\n        if first_display == \"\":\n            first_display = display\n        if str(display).strip() != \"\":\n            return display\n    return first_display\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 2 — UM-REVIT MAPPING READER  (identical to Script 2 v9.9.0)\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef read_um_revit_mapping(file_path):\n    um_map = {}\n    if not file_path:\n        return um_map\n    try:\n        _pkg_paths = [\n            r\"C:\\Dynamo\\2.16\\Python Support Pckg\",\n            r\"K:\\CAD\\_Revit2023\\Add_Ins\\Python Support Pckg\",\n        ]\n        for _p in _pkg_paths:\n            import os as _os\n            if _os.path.isdir(_p) and _p not in sys.path:\n                sys.path.insert(0, _p)\n                break\n        from openpyxl import load_workbook\n        wb = load_workbook(file_path, read_only=True, data_only=True)\n        if 'UM-Revit Mapping' not in wb.sheetnames:\n            wb.close()\n            return um_map\n        ws = wb['UM-Revit Mapping']\n        header_row  = [c.value for c in next(ws.iter_rows(min_row=3, max_row=3))]\n        family_cols = [str(h).strip() for h in header_row[2:] if h]\n        for row in ws.iter_rows(min_row=4, values_only=True):\n            excel_col   = row[0]\n            revit_param = row[1]\n            if not excel_col or not revit_param:\n                continue\n            key         = str(excel_col).strip().lower()\n            params_list = [p.strip() for p in str(revit_param).strip().split(',') if p.strip()]\n            applicable  = []\n            for i, fam_name in enumerate(family_cols):\n                col_idx = i + 2\n                if col_idx < len(row):\n                    cell_val = row[col_idx]\n                    if cell_val and str(cell_val).strip().lower() == \"yes\":\n                        applicable.append(fam_name)\n            if not applicable:\n                continue\n            if key not in um_map:\n                um_map[key] = {\"params\": [], \"families\": set()}\n            for p in params_list:\n                if p not in um_map[key][\"params\"]:\n                    um_map[key][\"params\"].append(p)\n            for f in applicable:\n                um_map[key][\"families\"].add(f)\n        wb.close()\n        for k in um_map:\n            um_map[k][\"families\"] = list(um_map[k][\"families\"])\n    except Exception:\n        pass\n    return um_map\n\n\ndef family_is_applicable(elem_family_name, applicable_families):\n    if not applicable_families:\n        return True\n    efn = elem_family_name.strip().lower()\n    for fam in applicable_families:\n        fam_lower = fam.strip().lower()\n        if fam_lower in efn or efn in fam_lower:\n            return True\n    return False\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 3 — COLLECT CONNECTOR ELEMENTS\n# ═══════════════════════════════════════════════════════════════════════════════\n\nall_doc_categories    = {c.Name: c for c in doc.Settings.Categories}\ncategories_to_process = categories_input if isinstance(categories_input, list) else [categories_input]\nall_elements = []\nfor item in categories_to_process:\n    cat_obj = None\n    if hasattr(item, 'Id'):\n        cat_obj = item\n    elif isinstance(item, str) and item in all_doc_categories:\n        cat_obj = all_doc_categories[item]\n    if cat_obj:\n        collector = (FilteredElementCollector(doc)\n                     .OfCategoryId(cat_obj.Id)\n                     .WhereElementIsNotElementType()\n                     .ToElements())\n        all_elements.extend(collector)\n\n# Restrict to connector families only — prevents Data Cubes from overwriting\n# connector entries in the lookup when both have Connection ID set.\nexisting_connectors = [\n    e for e in all_elements\n    if e.Symbol and \"Connector\" in (e.Symbol.Family.Name or \"\")\n]\n\n# ═══════════════════════════════════════════════════════════════════════════════\n# SECTION 4 — PARAMETER WRITE FUNCTION  (matches Script 2 v9.9.0 Section 9)\n# ═══════════════════════════════════════════════════════════════════════════════\n\ndef write_parameters_to_revit(data_input, key_param_name, file_path):\n    data = extract_flat_data(data_input)\n    if not data or not key_param_name:\n        return [[\"Error: Inputs are empty.\"]], [], 0, 0\n\n    um_revit_map = read_um_revit_mapping(file_path)\n\n    # Connection ID lowercase → connector element (connectors only)\n    element_lookup = {}\n    for el in existing_connectors:\n        p = el.LookupParameter(key_param_name)\n        if p:\n            val = get_param_display_value(p)\n            if val:\n                element_lookup[val.strip().lower()] = el\n\n    # Recover display-case column names from extractor Mapping metadata\n    col_case_map = {}\n    mapping_entries = safe_get(data_input, \"Mapping\")\n    if mapping_entries:\n        try:\n            for entry in mapping_entries:\n                orig = safe_get(entry, \"Excel Header\") or \"\"\n                if orig:\n                    col_case_map[str(orig).strip().lower()] = str(orig).strip()\n        except: pass\n\n    all_excel_cols = []\n    seen_lower     = set()\n    for mapped_lower, mapped_display in col_case_map.items():\n        if mapped_lower not in seen_lower:\n            seen_lower.add(mapped_lower)\n            all_excel_cols.append(mapped_display)\n\n    key_col_lower  = key_param_name.strip().lower()\n    writable_cols  = [c for c in all_excel_cols if c.strip().lower() != key_col_lower]\n    not_found_keys = set()\n    params_written = 0\n    params_skipped = 0\n\n    header_row = [\"Revit Element ID\", \"Connection ID\", \"Family\",\n                  \"Update Status\", \"Parameters Changed\"]\n    for col in writable_cols:\n        header_row.extend([\"Original: \" + col, \"Updated: \" + col])\n    processed_report = [header_row]\n\n    TransactionManager.Instance.EnsureInTransaction(doc)\n\n    for data_row in data:\n        key_value = safe_get(data_row, key_col_lower)\n        if key_value is None:\n            continue\n\n        element = element_lookup.get(str(key_value).strip().lower())\n        if not element:\n            not_found_keys.add(key_value)\n            continue\n\n        elem_fn        = get_family_name(element)\n        el_type        = doc.GetElement(element.GetTypeId())\n        inst_param_map = build_param_map(element)\n        type_param_map = build_param_map(el_type) if el_type else {}\n\n        element_was_updated = False\n        changed_excel_cols  = []\n        values_row = [element.Id.ToString(), str(key_value), elem_fn, \"Unchanged\", \"\"]\n\n        for col in writable_cols:\n            col_lower = col.strip().lower()\n            new_val   = safe_get(data_row, col_lower)\n\n            mapping_entry = um_revit_map.get(col_lower)\n            if mapping_entry:\n                revit_param_names   = mapping_entry[\"params\"]\n                applicable_families = mapping_entry[\"families\"]\n            else:\n                if col_lower in inst_param_map or col_lower in type_param_map:\n                    revit_param_names   = [col]\n                    applicable_families = []\n                else:\n                    values_row.extend([\"\", \"\"])\n                    continue\n\n            # Applicability check with unlisted-family fallback\n            if applicable_families and not family_is_applicable(elem_fn, applicable_families):\n                param_exists_on_elem = any(\n                    inst_param_map.get(rpn.strip().lower()) is not None or\n                    type_param_map.get(rpn.strip().lower()) is not None\n                    for rpn in revit_param_names\n                )\n                if not param_exists_on_elem:\n                    values_row.extend([\"\", \"\"])\n                    continue\n\n            # Pre-read before values\n            param_records = []\n            for rpn in revit_param_names:\n                rpn_lower = rpn.strip().lower()\n                p  = inst_param_map.get(rpn_lower)\n                tp = type_param_map.get(rpn_lower)\n                before = (get_param_display_value(p)  if p  is not None else\n                          get_param_display_value(tp) if tp is not None else \"\")\n                param_records.append((rpn_lower, p, tp, before))\n\n            primary_before = param_records[0][3] if param_records else \"\"\n\n            if new_val is None or str(new_val).strip() in (\"\", \"-\", \"None\", \"null\"):\n                values_row.extend([primary_before, primary_before])\n                params_skipped += 1\n                continue\n\n            first_changed_before = None\n            first_changed_param  = None\n            col_was_updated      = False\n\n            for rpn_lower, param_to_set, tp_match, before_display in param_records:\n                if param_to_set is not None and not param_to_set.IsReadOnly:\n                    changed, _ = compare_and_set_param(param_to_set, new_val)\n                    if changed:\n                        if first_changed_before is None:\n                            first_changed_before = before_display\n                            first_changed_param  = rpn_lower\n                        element_was_updated = True\n                        col_was_updated     = True\n                        params_written     += 1\n                    else:\n                        params_skipped += 1\n                elif tp_match is not None:\n                    if check_param_match(tp_match, new_val):\n                        params_skipped += 1\n                    else:\n                        family = el_type.Family\n                        for sym_id in family.GetFamilySymbolIds():\n                            sym    = doc.GetElement(sym_id)\n                            sym_pm = build_param_map(sym)\n                            sym_p  = sym_pm.get(rpn_lower)\n                            if sym_p and check_param_match(sym_p, new_val):\n                                if not sym.IsActive: sym.Activate()\n                                element.ChangeTypeId(sym_id)\n                                if first_changed_before is None:\n                                    first_changed_before = before_display\n                                    first_changed_param  = rpn_lower\n                                element_was_updated = True\n                                col_was_updated     = True\n                                el_type        = sym\n                                type_param_map = build_param_map(el_type)\n                                params_written += 1\n                                break\n\n            if element_was_updated:\n                doc.Regenerate()\n\n            current_type   = doc.GetElement(element.GetTypeId())\n            cur_inst_pm    = build_param_map(element)\n            cur_type_pm    = build_param_map(current_type) if current_type else {}\n            current_display = get_representative_display(\n                revit_param_names, cur_inst_pm, cur_type_pm,\n                preferred_name=first_changed_param\n            )\n\n            if first_changed_before is not None:\n                original_val_str = first_changed_before\n                final_val_str    = current_display\n            else:\n                original_val_str = primary_before\n                final_val_str    = (current_display if str(current_display).strip() != \"\"\n                                    else primary_before)\n\n            if col_was_updated:\n                changed_excel_cols.append(col)\n\n            values_row.extend([original_val_str, final_val_str])\n\n        if element_was_updated:\n            values_row[3] = \"Updated\"\n        values_row[4] = \", \".join(changed_excel_cols)\n\n        processed_report.append(values_row)\n\n    TransactionManager.Instance.TransactionTaskDone()\n\n    not_found_report = [[\"Key Value\", \"Status\"]]\n    for key in sorted(not_found_keys):\n        not_found_report.append([key, \"Element Not Found in Revit\"])\n\n    if len(processed_report) <= 1:\n        processed_report = [[\"No matching elements were found to process.\"]]\n\n    return processed_report, not_found_report, params_written, params_skipped\n\n\nparam_results = write_parameters_to_revit(extractor_output, key_parameter, excel_file_path)\nOUT = [param_results[0], param_results[1]]\n",
      "Engine": "CPython3",
