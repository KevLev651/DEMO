    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# ╔══════════════════════════════════════════════════════════════════╗\n# ║  MCC Annotation Placer + Parameter Filler                      ║\n# ║  Revit 2023 / Dynamo 2.x                                      ║\n# ║  Groups of 13, new row every 13 (drops Y, resets X)            ║\n# ╚══════════════════════════════════════════════════════════════════╝\n\nimport clr\nclr.AddReference('RevitAPI')\nclr.AddReference('RevitServices')\nclr.AddReference('RevitNodes')\n\nfrom Autodesk.Revit.DB import *\nfrom RevitServices.Persistence import DocumentManager\nfrom RevitServices.Transactions import TransactionManager\n\n# ── DYNAMO INPUTS ────────────────────────────────────────────────\n# IN[0] : Excel Data         — Data.ImportExcel output (list of lists)\n#                               Sheet: \"MCC Info\"\n# IN[1] : Header Row Index   — Row index of headers (0-based), typically 0\n# IN[2] : Family Type Column — Column index for Family Type (col G = 6)\n# IN[3] : Spacing (ft)       — Horizontal distance between placed families\n# IN[4] : Start X (ft)       — X origin for first placement\n# IN[5] : Start Y (ft)       — Y origin for placement row\n# ─────────────────────────────────────────────────────────────────\n\nraw_excel = IN[0]\nheader_row_index = int(IN[1])\nfamilytype_col   = int(IN[2])\nspacing          = float(IN[3])\nstart_x          = float(IN[4])\nstart_y          = float(IN[5])\n\n# ── LAYOUT CONFIG ────────────────────────────────────────────────\nGROUP_SIZE = 13        # families per row\nROW_DROP   = .75       # Y offset (feet) between rows (negative = downward)\n\ndoc = DocumentManager.Instance.CurrentDBDocument\nactive_view = doc.ActiveView\n\n# ── FLATTEN EXCEL DATA ───────────────────────────────────────────\ndef flatten_excel(data):\n    rows = []\n    try:\n        for row in data:\n            r = []\n            for cell in row:\n                r.append(str(cell) if cell is not None else \"\")\n            rows.append(r)\n    except:\n        pass\n    return rows\n\nexcel_data = flatten_excel(raw_excel)\n\n# ── DIAGNOSTIC ───────────────────────────────────────────────────\ndiag = []\ndiag.append(\"Row count: {}\".format(len(excel_data)))\nif len(excel_data) > header_row_index:\n    diag.append(\"Headers: {}\".format(excel_data[header_row_index]))\n\n# ── PARSE HEADERS ────────────────────────────────────────────────\nheaders = []\nif len(excel_data) > header_row_index:\n    headers = [str(h).strip() for h in excel_data[header_row_index]]\n\ndef col_index(name):\n    try:\n        return headers.index(name)\n    except ValueError:\n        return -1\n\n# ── EXCEL HEADER → REVIT PARAMETER NAME ──────────────────────────\nPARAM_MAP = [\n    (\"EQUIP ID\",         \"Equipment ID\"),\n    (\"MCC\",              \"MCC\"),\n    (\"BUCKET\",           \"Unit Number\"),\n    (\"BUCKET TYPE\",      \"Unit Type\"),\n    (\"DESCRIPTION\",      \"Equipment Description\"),\n    (\"SF\",               \"Space Factor\"),\n    (\"MOTOR HP\",         \"Motor HP\"),\n    (\"STARTER HP RATING\",\"Elec Starter Size\"),\n    (\"STARTER SIZE\",     \"Elec Starter Size\"),\n    (\"VFD AMP RATING\",   \"VFD Output Current\"),\n    (\"CB TRIP\",          \"Breaker Trip\"),\n    (\"CB FRAME\",         \"Breaker Frame\"),\n    (\"FUSE TRIP\",        \"Fuse Trip\"),\n    (\"CABLE\",            \"Wire Size\"),\n]\n\ncol_map = []\nseen_revit = set()\nfor excel_name, revit_name in PARAM_MAP:\n    idx = col_index(excel_name)\n    if idx >= 0 and revit_name not in seen_revit:\n        col_map.append((excel_name, revit_name, idx))\n        seen_revit.add(revit_name)\n\ndiag.append(\"Active mappings: {}\".format(len(col_map)))\n\n# ── FAMILY SYMBOL LOOKUP ─────────────────────────────────────────\ncollector = (FilteredElementCollector(doc)\n             .OfClass(FamilySymbol)\n             .OfCategory(BuiltInCategory.OST_GenericAnnotation))\n\nsymbol_dict = {}\nfor sym in collector:\n    symbol_dict[sym.get_Name()] = sym\n\n# ── SET PARAMETER ────────────────────────────────────────────────\ndef set_param(element, param_name, value):\n    val = str(value).strip() if value is not None else \"\"\n    if val == \"\" or val.lower() == \"none\":\n        return \"skip\"\n\n    targets = [element]\n    tid = element.GetTypeId()\n    if tid != ElementId.InvalidElementId:\n        targets.append(doc.GetElement(tid))\n\n    for target in targets:\n        if target is None:\n            continue\n        p = target.LookupParameter(param_name)\n        if p is not None and not p.IsReadOnly:\n            if _write(p, val):\n                return \"OK\"\n        key = param_name.lower().replace(\" \", \"\")\n        for p in target.Parameters:\n            if p.Definition.Name.lower().replace(\" \", \"\") == key:\n                if not p.IsReadOnly and _write(p, val):\n                    return \"OK-fuzzy\"\n\n    return \"FAIL\"\n\ndef _write(p, val):\n    try:\n        st = p.StorageType\n        if st == StorageType.String:\n            p.Set(val)\n            return True\n        elif st == StorageType.Double:\n            p.Set(float(val))\n            return True\n        elif st == StorageType.Integer:\n            p.Set(int(round(float(val))))\n            return True\n    except:\n        pass\n    return False\n\n# ── PLACE & FILL ─────────────────────────────────────────────────\ndata_rows = excel_data[header_row_index + 1:]\nplaced = []\nerrors = []\nparam_log = []\n\nTransactionManager.Instance.EnsureInTransaction(doc)\n\nx_pos = start_x\ny_pos = start_y\ncount_in_row = 0  # tracks how many placed in current row\n\nfor i, row in enumerate(data_rows):\n    if familytype_col >= len(row):\n        errors.append(\"Row {}: col out of range\".format(i))\n        continue\n\n    type_name = row[familytype_col].strip()\n    if not type_name or type_name == \"None\":\n        continue\n\n    if type_name not in symbol_dict:\n        errors.append(\"Row {}: '{}' not in project\".format(i, type_name))\n        continue\n\n    symbol = symbol_dict[type_name]\n    if not symbol.IsActive:\n        symbol.Activate()\n        doc.Regenerate()\n\n    # Check if we need to start a new row\n    if count_in_row >= GROUP_SIZE:\n        x_pos = start_x\n        y_pos -= ROW_DROP  # drop down (negative Y = down in Revit)\n        count_in_row = 0\n\n    # Place\n    point = XYZ(x_pos, y_pos, 0)\n    instance = doc.Create.NewFamilyInstance(point, symbol, active_view)\n    doc.Regenerate()\n\n    # Fill parameters\n    row_log = []\n    for excel_name, revit_name, ci in col_map:\n        if ci >= len(row):\n            continue\n        cell = row[ci]\n        result = set_param(instance, revit_name, cell)\n        row_log.append(\"{} = '{}' [{}]\".format(revit_name, cell, result))\n\n    equip_col = col_index(\"EQUIP ID\")\n    eid = row[equip_col].strip() if 0 <= equip_col < len(row) else \"?\"\n    placed.append(\"{} | {} @ ({}, {})\".format(eid, type_name, round(x_pos, 2), round(y_pos, 2)))\n    param_log.append(\"--- {} ---\".format(eid))\n    param_log.extend(row_log)\n\n    x_pos += spacing\n    count_in_row += 1\n\nTransactionManager.Instance.TransactionTaskDone()\n\n# ── OUTPUT ───────────────────────────────────────────────────────\n# OUT[0] = placed summary (now shows X,Y coords)\n# OUT[1] = errors\n# OUT[2] = parameter fill log\n# OUT[3] = diagnostics\nOUT = [placed, errors, param_log, diag]",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "c2dc4a011b114e69a057db7cd910a6fb",
      "Inputs": [
        {
          "Id": "51e6ae31329640d9a5bf75879ea46abf",
          "Name": "IN[0]",
          "Description": "Excel data",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "aea4ca799a074b5ca5e9f7234271a2e9",
